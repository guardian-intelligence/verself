# Two distinct toolchain registrations: target/platform constraints (so
# zig_configure_binary can transition to e.g. linux/x86_64/musl) and the host
# Zig SDK that actually runs the compiler. Removing either breaks Zig builds.
register_toolchains("@rules_zig//zig/target:all")

register_toolchains("@zig_toolchains//:all")

go_sdk = use_extension("@io_bazel_rules_go//go:extensions.bzl", "go_sdk")
