{
  "name": "@forge-metal/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI primitives for the Vite+ rent-a-sandbox workspace.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
