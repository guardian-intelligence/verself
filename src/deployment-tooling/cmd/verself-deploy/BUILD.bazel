load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "verself-deploy_lib",
    srcs = [
        "ansible_run.go",
        "main.go",
        "nomad_deploy_all.go",
        "nomad_submit.go",
        "paths.go",
        "run.go",
        "substrate.go",
        "with_otel.go",
    ],
    importpath = "github.com/verself/deployment-tooling/cmd/verself-deploy",
    visibility = ["//visibility:private"],
    deps = [
        "//src/deployment-tooling/internal/ansible",
        "//src/deployment-tooling/internal/bazelbuild",
        "//src/deployment-tooling/internal/caddyupstreams",
        "//src/deployment-tooling/internal/garage",
        "//src/deployment-tooling/internal/identity",
        "//src/deployment-tooling/internal/layers",
        "//src/deployment-tooling/internal/ledger",
        "//src/deployment-tooling/internal/nomadclient",
        "//src/deployment-tooling/internal/render",
        "//src/deployment-tooling/internal/runtime",
        "//src/deployment-tooling/internal/sshtun",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

go_binary(
    name = "verself-deploy",
    embed = [":verself-deploy_lib"],
    visibility = ["//visibility:public"],
)
