load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "runtime",
    srcs = ["bootstrap.go"],
    importpath = "github.com/verself/deployment-tooling/internal/runtime",
    visibility = ["//src/deployment-tooling:__subpackages__"],
    deps = [
        "//src/deployment-tooling/internal/chwriter",
        "//src/deployment-tooling/internal/identity",
        "//src/deployment-tooling/internal/inventory",
        "//src/deployment-tooling/internal/sshtun",
        "//src/otel",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//baggage",
        "@io_opentelemetry_go_otel//propagation",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

alias(
    name = "go_default_library",
    actual = ":runtime",
    visibility = ["//src/deployment-tooling:__subpackages__"],
)
