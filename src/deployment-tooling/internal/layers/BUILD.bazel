load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "layers",
    srcs = ["layers.go"],
    importpath = "github.com/verself/deployment-tooling/internal/layers",
    visibility = ["//src/deployment-tooling:__subpackages__"],
    deps = [
        "//src/deployment-tooling/internal/ansible",
        "//src/deployment-tooling/internal/bazelbuild",
        "//src/deployment-tooling/internal/chwriter",
        "//src/deployment-tooling/internal/ledger",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

alias(
    name = "go_default_library",
    actual = ":layers",
    visibility = ["//src/deployment-tooling:__subpackages__"],
)
