load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "nomad-deploy_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/cue-renderer/cmd/nomad-deploy",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "nomad-deploy",
    embed = [":nomad-deploy_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "nomad-deploy_test",
    srcs = ["main_test.go"],
    embed = [":nomad-deploy_lib"],
)
