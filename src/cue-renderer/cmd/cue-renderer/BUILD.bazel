load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "cue-renderer_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/cue-renderer/cmd/cue-renderer",
    visibility = ["//visibility:private"],
    deps = [
        "//src/cue-renderer/internal/load",
        "//src/cue-renderer/internal/render",
        "//src/cue-renderer/internal/render/clusters",
        "//src/cue-renderer/internal/render/components",
        "//src/cue-renderer/internal/render/dns",
        "//src/cue-renderer/internal/render/endpoints",
        "//src/cue-renderer/internal/render/nftables",
        "//src/cue-renderer/internal/render/nomad",
        "//src/cue-renderer/internal/render/ops",
        "//src/cue-renderer/internal/render/postgres",
        "//src/cue-renderer/internal/render/routes",
        "//src/cue-renderer/internal/render/spire",
        "//src/cue-renderer/internal/spans",
        "@io_opentelemetry_go_otel//attribute",
    ],
)

go_binary(
    name = "cue-renderer",
    embed = [":cue-renderer_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "cue-renderer_test",
    srcs = ["main_test.go"],
    data = ["//src/cue-renderer:topology_srcs"],
    embed = [":cue-renderer_lib"],
    deps = [
        "//src/cue-renderer/internal/load",
        "//src/cue-renderer/internal/render",
    ],
)
