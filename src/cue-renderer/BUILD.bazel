# Filegroup of every CUE source the loader walks. Tests in the renderer
# tree depend on this via `data` so they can resolve the topology dir
# from runfiles via TEST_SRCDIR.
filegroup(
    name = "topology_srcs",
    srcs = TOPOLOGY_SRCS,
    visibility = ["//src/cue-renderer:__subpackages__"],
)

genrule(
    name = "bazel_module_render",
    srcs = TOPOLOGY_SRCS,
    outs = ["server_tools.MODULE.bazel"],
    cmd = "$(location //src/cue-renderer/cmd/cue-renderer) render bazel_module > $@",
    tools = ["//src/cue-renderer/cmd/cue-renderer"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "bazel_nftables_render",
    srcs = TOPOLOGY_SRCS,
    outs = ["nftables_files.bzl.gen"],
    cmd = "$(location //src/cue-renderer/cmd/cue-renderer) render bazel_nftables > $@",
    tools = ["//src/cue-renderer/cmd/cue-renderer"],
    visibility = ["//visibility:public"],
)

