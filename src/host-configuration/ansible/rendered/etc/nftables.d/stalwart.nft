# nftables ruleset stalwart.
table inet verself_stalwart
delete table inet verself_stalwart

table inet verself_stalwart {
    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != stalwart accept
        oifname "lo" accept
        tcp dport 53 accept
        udp dport 53 accept

        drop
    }
}
