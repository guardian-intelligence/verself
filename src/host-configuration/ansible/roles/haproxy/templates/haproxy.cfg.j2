backend be_firecracker_forgejo
  guid be_firecracker_forgejo
  http-request set-header Host {{ forgejo_domain }}
  http-request set-header X-Forwarded-Host {{ forgejo_domain }}
  server forgejo {{ topology_endpoints.forgejo.endpoints.http.address }} guid be_firecracker_forgejo_srv_forgejo

backend be_garage_nomad_artifacts
  guid be_garage_nomad_artifacts
  balance random
{% for garage_node in topology_clusters.garage.nodes %}
  server garage_{{ loop.index0 }} {{ topology_clusters.garage.host }}:{{ garage_node.s3_port }} guid be_garage_nomad_artifacts_srv_garage_{{ loop.index0 }}
{% endfor %}

{% for route in topology_routes | selectattr('gateway', 'equalto', 'public_haproxy') %}
backend {{ backend_name(route) }}
  guid {{ backend_name(route) }}
{% if route.kind == 'operator_origin' %}
  http-request set-header Host %[req.hdr(host)]
  http-request set-header X-Forwarded-Host %[req.hdr(host)]
  http-request set-header X-Forwarded-Proto https
  server pomerium {{ topology_endpoints.pomerium.endpoints.http.address }} guid {{ backend_name(route) }}_srv_pomerium
{% elif route.to.component == 'zitadel' %}
  server zitadel {{ topology_endpoints.zitadel.endpoints.http.address }} proto h2 guid {{ backend_name(route) }}_srv_zitadel
{% elif route.to.component == 'stalwart' %}
  acl jmap_session path -i /jmap/session
  acl stalwart_direct path -i /.well-known/jmap
  acl stalwart_direct path_beg /jmap/ /auth/
  acl mail_allowed path -i /jmap/session /.well-known/jmap
  acl mail_allowed path_beg /jmap/ /auth/
  http-request set-var(txn.upstream_addr) str(VERSELF_UPSTREAM_MAILBOX_SERVICE_PUBLIC_HTTP),map({{ haproxy_map_dir }}/upstreams.map) if jmap_session
  acl valid_mailbox_upstream var(txn.upstream_addr) -m reg ^127\.0\.0\.1:[0-9]+$
  http-request deny deny_status 502 if jmap_session !valid_mailbox_upstream
  http-request set-dst var(txn.upstream_addr),field(1,:) if jmap_session
  http-request set-dst-port var(txn.upstream_addr),field(2,:) if jmap_session
  http-request return status 404 unless mail_allowed
  use-server mailbox if jmap_session
  use-server stalwart if stalwart_direct !jmap_session
  server mailbox 0.0.0.0:0 proto h2 guid {{ backend_name(route) }}_srv_mailbox
  server stalwart {{ topology_endpoints.stalwart.endpoints.http.address }} guid {{ backend_name(route) }}_srv_stalwart
{% elif route.to.component == 'source_code_hosting_service' and route.to.interface == 'git_smart_http' %}
  acl source_git method GET POST
  acl source_git_path path_reg ^/[^/]+/[^/]+\.git/(info/refs|git-upload-pack|git-receive-pack)$
  http-request return status 404 unless source_git source_git_path
  http-request set-header X-Forwarded-Host {{ forgejo_domain }}
  http-request set-header X-Forwarded-Proto https
{{ dynamic_nomad_backend(route, 'h2c') }}
{% else %}
{% if route.kind == 'public_api_origin' %}
{{ api_security_headers() }}
  http-request return status 404 unless { path_beg /api/ }
{% elif route.kind == 'browser_origin' and route.to.interface == 'frontend' %}
{{ frontend_security_headers() }}
{% elif route.kind == 'browser_origin' %}
{{ api_security_headers() }}
{% endif %}
{% if route.max_body_bytes | int > 0 %}
{{ body_limit_rules(route.max_body_bytes | int) }}
{% endif %}
{{ dynamic_nomad_backend(route, 'h2c' if route.to.component in haproxy_h2c_components else 'http') }}
{% endif %}

{% endfor %}
