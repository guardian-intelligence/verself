  http-request deny deny_status 502 unless valid_nomad_upstream
  http-request set-dst var(txn.upstream_addr),field(1,:)
  http-request set-dst-port var(txn.upstream_addr),field(2,:)
  server dyn 0.0.0.0:0 proto h2 guid be_billing_stripe_webhook_srv_dyn

