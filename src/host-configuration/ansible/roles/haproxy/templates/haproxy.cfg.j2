# Generated by github.com/verself/host-configuration/edgecontract. Edit topology inputs, then run aspect operator edge --action=render.

global
  log stdout format raw local0
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
  crt-base {{ haproxy_cert_dir }}
  maxconn {{ haproxy_global_maxconn }}
  strict-limits
  hard-stop-after 5s
  # Required for shm-stats-file. URI normalization remains disabled while HAProxy marks normalizers experimental.
  expose-experimental-directives
  shm-stats-file {{ haproxy_shm_stats_file }}
  ssl-default-bind-options ssl-min-ver TLSv1.3 no-tls-tickets
  ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256

defaults
  mode http
  log global
  option dontlognull
  option http-keep-alive
  timeout connect 1s
  timeout client 30s
  timeout server 30s
  timeout tunnel 4h
  timeout http-request 5s
  timeout http-keep-alive 10s
  unique-id-format %[uuid()]
  unique-id-header X-Request-ID
  log-format "request_id=%ID client_ip=%ci client_port=%cp method=%HM host=%[var(txn.host)] path=%HP query=%HQ uri=%HU status=%ST bytes=%B duration_ms=%Ta t_request_ms=%TR t_queue_ms=%Tw t_connect_ms=%Tc t_response_ms=%Tr termination=%tsc active_conn=%ac frontend_conn=%fc backend_conn=%bc server_conn=%sc retries=%rc server_queue=%sq backend_queue=%bq frontend=%ft backend=%b server=%s tls_version=%[ssl_fc_protocol] tls_cipher=%[ssl_fc_cipher] tls_sni=%[ssl_fc_sni] alpn=%[ssl_fc_alpn]"

frontend fe_http
  guid fe_http
  maxconn {{ haproxy_public_frontend_maxconn }}
  bind 0.0.0.0:80
  http-request set-var(txn.host) req.hdr(host),lower,field(1,:)
  http-request redirect scheme https code 308

frontend fe_https
  guid fe_https
  maxconn {{ haproxy_public_frontend_maxconn }}
  bind 0.0.0.0:443 ssl crt {{ haproxy_cert_dir }} strict-sni alpn h2,http/1.1
  http-request set-var(txn.host) req.hdr(host),lower,field(1,:)
  acl from_cloudflare src {{ haproxy_cloudflare_trusted_proxies | join(' ') }}
  http-request set-src req.hdr(CF-Connecting-IP) if from_cloudflare { req.hdr(CF-Connecting-IP) -m found }
  http-request set-header X-Real-IP %[src]
  http-request set-header X-Forwarded-For %[src]
  http-request set-header X-Forwarded-Host %[req.hdr(host)]
  http-request set-header X-Forwarded-Proto https
  http-response set-header Strict-Transport-Security "{{ haproxy_hsts_header }}"

  acl host_verself var(txn.host) -m str verself.sh
  acl host_billing var(txn.host) -m str billing.api.verself.sh
  acl host_sandbox var(txn.host) -m str sandbox.api.verself.sh
  acl host_source var(txn.host) -m str source.api.verself.sh
  acl host_zitadel var(txn.host) -m str auth.verself.sh
  acl method_get method GET
  acl method_post method POST
  acl stripe_webhook path -i /webhooks/stripe
  acl stripe_source src {{ haproxy_stripe_webhook_ips | join(' ') }}
  acl auth_path path -i /api/v1/auth/login /api/v1/auth/callback /api/v1/auth/session /api/v1/auth/organization /api/v1/auth/logout
  acl sandbox_actions_webhook path -i /webhooks/github/actions /webhooks/forgejo/actions
  acl source_forgejo_webhook path -i /webhooks/forgejo
  acl edge_public_rate_limited sc_http_req_rate(0,be_edge_public_rates) gt {{ haproxy_public_rate_limit }}
  acl edge_auth_rate_limited sc_http_req_rate(1,be_edge_auth_rates) gt {{ haproxy_auth_rate_limit }}
  acl edge_webhook_rate_limited sc_http_req_rate(2,be_edge_webhook_rates) gt {{ haproxy_webhook_rate_limit }}

  http-request track-sc0 src table be_edge_public_rates
  http-request track-sc1 src table be_edge_auth_rates if host_verself auth_path
  http-request track-sc2 src table be_edge_webhook_rates if host_billing stripe_webhook
  http-request track-sc2 src table be_edge_webhook_rates if host_sandbox sandbox_actions_webhook
  http-request track-sc2 src table be_edge_webhook_rates if host_source source_forgejo_webhook
  http-request return status 429 content-type text/plain string "rate limit exceeded" if edge_public_rate_limited
  http-request return status 429 content-type text/plain string "rate limit exceeded" if host_verself auth_path edge_auth_rate_limited
  http-request return status 429 content-type text/plain string "rate limit exceeded" if host_billing stripe_webhook edge_webhook_rate_limited
  http-request return status 429 content-type text/plain string "rate limit exceeded" if host_sandbox sandbox_actions_webhook edge_webhook_rate_limited
  http-request return status 429 content-type text/plain string "rate limit exceeded" if host_source source_forgejo_webhook edge_webhook_rate_limited

  http-request return status 403 if host_billing stripe_webhook method_post !stripe_source
  http-request return status 405 if host_billing stripe_webhook !method_post
  http-request return status 405 if host_sandbox { path -i /webhooks/github/actions } !method_post
  http-request return status 405 if host_sandbox { path -i /webhooks/forgejo/actions } !method_post
  http-request return status 405 if host_sandbox { path -i /github/installations/callback } !method_get
  http-request return status 405 if host_zitadel { path -i /internal/zitadel/actions/api-credential-claims } !method_post

  use_backend be_billing_stripe_webhook if host_billing stripe_webhook method_post stripe_source
  use_backend be_sandbox_github_actions_webhook if host_sandbox method_post { path -i /webhooks/github/actions }
  use_backend be_sandbox_forgejo_actions_webhook if host_sandbox method_post { path -i /webhooks/forgejo/actions }
  use_backend be_sandbox_github_installation_callback if host_sandbox method_get { path -i /github/installations/callback }
  use_backend be_sandbox_small_json_mutation if host_sandbox method_post { path -i /api/v1/billing/checkout /api/v1/billing/contracts }
  use_backend be_sandbox_execution_submit if host_sandbox method_post { path -i /api/v1/executions }
  use_backend be_sandbox_execution_schedule_create if host_sandbox method_post { path -i /api/v1/execution-schedules }
  use_backend be_source_forgejo_webhook if host_source { path -i /webhooks/forgejo }
  use_backend be_zitadel_action_api_credentials if host_zitadel method_post { path -i /internal/zitadel/actions/api-credential-claims }

  acl route_1_host var(txn.host) -m str verself.sh
  acl route_1_path path -i /api/v1/auth/login /api/v1/auth/callback /api/v1/auth/session /api/v1/auth/organization /api/v1/auth/logout
  use_backend be_route_product_apex_identity_service_public_api if route_1_host route_1_path
  use_backend %[var(txn.host),map({{ haproxy_map_dir }}/public-hosts.map,be_not_found)]

frontend fe_haproxy_metrics
  guid fe_haproxy_metrics
  maxconn {{ haproxy_metrics_frontend_maxconn }}
  bind 127.0.0.1:8404
  option socket-stats
  http-request use-service prometheus-exporter if { path -i /metrics }
  http-request return status 404

frontend fe_firecracker_host_http
  guid fe_firecracker_host_http
  maxconn {{ haproxy_internal_frontend_maxconn }}
  bind 10.255.0.1:18080
  http-request set-var(txn.host) req.hdr(host),lower,field(1,:)
  http-request set-header X-Forwarded-Proto http
  acl method_get method GET
  acl method_post method POST
  acl forgejo_actions path -i /api/actions
  acl forgejo_actions_prefix path_beg /api/actions/
  acl forgejo_smart_http path_reg ^/[^/]+/[^/]+\.git/(info/refs|git-upload-pack)$
  use_backend be_firecracker_sandbox_h2c if method_get { path -i /internal/sandbox/v1/github-runner-jit }
  use_backend be_firecracker_sandbox_h2c if method_get { path -i /internal/sandbox/v1/runner-bootstrap }
  use_backend be_firecracker_sandbox_h2c if { path_beg /internal/sandbox/v1/stickydisk/ }
  use_backend be_firecracker_sandbox_h2c if method_post { path -i /internal/sandbox/v1/github-checkout/bundle }
  use_backend be_firecracker_forgejo if method_get forgejo_actions
  use_backend be_firecracker_forgejo if method_post forgejo_actions
  use_backend be_firecracker_forgejo if method_get forgejo_actions_prefix
  use_backend be_firecracker_forgejo if method_post forgejo_actions_prefix
  use_backend be_firecracker_forgejo if method_get forgejo_smart_http
  use_backend be_firecracker_forgejo if method_post forgejo_smart_http
  default_backend be_forbidden

frontend fe_nomad_artifacts
  guid fe_nomad_artifacts
  maxconn {{ haproxy_internal_frontend_maxconn }}
  bind 127.0.0.1:9443 ssl crt /etc/verself/pki/nomad-artifacts-server-haproxy.pem alpn h2,http/1.1
  http-request set-var(txn.host) req.hdr(host),lower,field(1,:)
  default_backend be_garage_nomad_artifacts

backend be_edge_public_rates
  guid be_edge_public_rates
  stick-table type ip size {{ haproxy_stick_table_size }} expire {{ haproxy_stick_table_expire }} store http_req_rate({{ haproxy_public_rate_window }}),http_err_rate({{ haproxy_public_rate_window }})

backend be_edge_auth_rates
  guid be_edge_auth_rates
  stick-table type ip size {{ haproxy_stick_table_size }} expire {{ haproxy_stick_table_expire }} store http_req_rate({{ haproxy_public_rate_window }}),http_err_rate({{ haproxy_public_rate_window }})

backend be_edge_webhook_rates
