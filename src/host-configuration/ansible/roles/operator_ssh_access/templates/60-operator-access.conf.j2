# Managed by Ansible - operator_ssh_access role.

TrustedUserCAKeys {{ operator_ssh_access_trusted_user_ca_path }}
AllowUsers {{ operator_ssh_access_user }}
PasswordAuthentication no
KbdInteractiveAuthentication no

# Pomerium owns public :22 and forwards authorised native-SSH sessions here.
ListenAddress {{ operator_ssh_access_upstream_address }}:{{ operator_ssh_access_upstream_port }}

# Direct SSH stays available for bootstrap/recovery before identity is healthy.
ListenAddress {{ operator_ssh_access_bootstrap_address }}:{{ operator_ssh_access_bootstrap_port }}

Match LocalPort {{ operator_ssh_access_upstream_port }}
    AuthorizedKeysFile none
