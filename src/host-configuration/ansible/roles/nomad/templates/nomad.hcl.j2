# {{ ansible_managed }}
# Single-node Nomad: server + client co-resident. Listens on loopback only;
# remote operator access is via wg-ops or SSH-forwarded loopback. raw_exec
# is the only enabled task driver — workloads run as host processes under
# the topology-declared uid so they keep peer-auth access to the Postgres
# Unix socket and the SPIRE workload-API socket. The exec driver's
# chroot/PID-namespace isolation would cut both.

data_dir  = "{{ nomad_data_dir }}"
log_level = "INFO"

bind_addr = "{{ topology_endpoints.nomad.host }}"

# HTTP is the only port mirrored into topology — operators connect here
# over wg-ops or SSH-forwarded loopback. RPC (4647) and Serf (4648) stay
# on Nomad's defaults; both are loopback-only on a single-node deploy
# and the host firewall already drops non-loopback ingress.
ports {
  http = {{ topology_endpoints.nomad.endpoints.http.port }}
}

# Nomad refuses to advertise loopback automatically (it considers
# defaulting unsafe), but on a single-node deploy loopback is exactly
# what we want. Spell it out per-protocol so the client/server pair
# inside the same process can talk RPC on 4647 and gossip on 4648.
advertise {
  http = "{{ topology_endpoints.nomad.endpoints.http.address }}"
  rpc  = "127.0.0.1:4647"
  serf = "127.0.0.1:4648"
}

server {
  enabled          = true
  bootstrap_expect = 1
}

client {
  enabled = true
  min_dynamic_port = 20000
  max_dynamic_port = 32000

  # Single-node: server is co-resident on loopback. Setting servers
  # explicitly skips Consul discovery (we don't run Consul).
  servers = ["127.0.0.1:4647"]

  artifact {
    set_environment_variables = "AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY,AWS_REGION,AWS_EC2_METADATA_DISABLED"
  }

  # The dynamic port range above is mirrored by the static nftables perimeter
  # rules that drop non-loopback ingress to allocation listeners.
  # Pin every named host-network port to 127.0.0.1 so the native service
  # registry advertises loopback for HTTP/TCP checks. Components bind
  # 127.0.0.1 at L4; nftables enforces loopback-only at L3 as defense-in-depth.
  # Filtering by CIDR avoids fingerprinting ::1 alongside 127.0.0.1
  # (per hashicorp/nomad#15341).
  host_network "loopback" {
    cidr = "127.0.0.0/8"
  }
}

# Disable Consul auto-discovery: we don't run a Consul agent, so leaving
# auto_advertise on produces a steady stream of refused connections in
# the Nomad log.
consul {
  auto_advertise   = false
  client_auto_join = false
  server_auto_join = false
}

plugin "raw_exec" {
  config {
    enabled = true
  }
}
# exec/java/qemu drivers are off by default in Nomad and we never opt
# them in. raw_exec above is the single driver this node accepts;
# `nomad node status -self` will reflect that.

telemetry {
  collection_interval        = "10s"
  disable_hostname           = true
  prometheus_metrics         = true
  publish_allocation_metrics = true
  publish_node_metrics       = true
}

acl {
  enabled = false
}
