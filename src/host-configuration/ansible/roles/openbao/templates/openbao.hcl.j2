ui = false

api_addr = "https://{{ topology_endpoints.openbao.endpoints.api.address }}"
cluster_addr = "https://{{ topology_endpoints.openbao.endpoints.cluster.address }}"

storage "raft" {
  path = "{{ openbao_raft_dir }}"
  node_id = "{{ openbao_node_id }}"
}

listener "tcp" {
  // bind_address reflects the topology endpoint's listen_host (0.0.0.0
  // when the API is exposed to wg-ops, 127.0.0.1 otherwise). The
  // companion nftables rule on verself_openbao restricts which iifname
  // can reach the bound socket so substrate workloads continue to talk
  // to it loopback while operator laptops on wg-ops can run
  // `bao login -method=oidc` for SSH cert issuance.
  address = "{{ topology_endpoints.openbao.endpoints.api.bind_address }}"
  cluster_address = "{{ topology_endpoints.openbao.endpoints.cluster.bind_address }}"
  tls_cert_file = "{{ openbao_tls_dir }}/cert.pem"
  tls_key_file = "{{ openbao_tls_dir }}/key.pem"
  tls_min_version = "tls13"

  telemetry {
    unauthenticated_metrics_access = true
  }
}

telemetry {
  prometheus_retention_time = "1m"
  disable_hostname = true
}

audit "file" "verself" {
  description = "Verself forensic backstop audit log"
  options {
    file_path = "{{ openbao_audit_log }}"
    mode = "0600"
  }
}
