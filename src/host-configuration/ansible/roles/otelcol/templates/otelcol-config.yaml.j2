receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:{{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }}
      http:
        endpoint: 127.0.0.1:{{ topology_endpoints.otelcol.endpoints.otlp_http.port }}
  journald/haproxy:
    units: [haproxy]
    resource:
      service.name: haproxy
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: regex_parser
        parse_from: body
        regex: '^request_id=(?P<request_id>[^ ]+) client_ip=(?P<client_ip>[^ ]+) client_port=(?P<client_port>[0-9]+) method=(?P<http_method>[^ ]+) host=(?P<http_host>[^ ]*) path=(?P<http_uri>[^ ]*) query=(?P<http_query>[^ ]*) uri=(?P<http_full_uri>[^ ]*) status=(?P<http_status>[0-9]+) bytes=(?P<resp_size_bytes>-|[0-9]+) duration_ms=(?P<duration_ms>-|[0-9]+) t_request_ms=(?P<t_request_ms>-|[0-9]+) t_queue_ms=(?P<t_queue_ms>-|[0-9]+) t_connect_ms=(?P<t_connect_ms>-|[0-9]+) t_response_ms=(?P<t_response_ms>-|[0-9]+) termination=(?P<termination_state>[^ ]+) active_conn=(?P<active_conn>[0-9]+) frontend_conn=(?P<frontend_conn>[0-9]+) backend_conn=(?P<backend_conn>[0-9]+) server_conn=(?P<server_conn>[0-9]+) retries=(?P<retries>[0-9]+) server_queue=(?P<server_queue>[0-9]+) backend_queue=(?P<backend_queue>[0-9]+) frontend=(?P<frontend>[^ ]+) backend=(?P<backend>[^ ]+) server=(?P<server>[^ ]+) tls_version=(?P<tls_version>[^ ]*) tls_cipher=(?P<tls_cipher>[^ ]*) tls_sni=(?P<tls_sni>[^ ]*) alpn=(?P<alpn>[^ ]*)$'
  journald/zitadel:
    units: [zitadel]
    resource:
      service.name: zitadel
    operators:
      # The journald receiver emits body as map[string]interface{} (Go map,
      # not a JSON string). Extract the MESSAGE field to body first, then
      # parse the Zitadel JSON log (slog.JSONHandler output).
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.TraceID
        span_id:
          parse_from: attributes.SpanID
        if: attributes.TraceID != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      # Flatten nested request object
      - type: move
        from: attributes.request.id
        to: attributes.request_id
        if: attributes.request != nil
      - type: move
        from: attributes.request.instance_host
        to: attributes.instance_host
        if: attributes.request != nil
      # Rename to avoid collision with OTel resource service.name
      - type: move
        from: attributes.service
        to: attributes.zitadel_service
        if: attributes.service != nil
      # Clean up parsed intermediate fields
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.TraceID
        if: attributes.TraceID != nil
      - type: remove
        field: attributes.SpanID
        if: attributes.SpanID != nil
      - type: remove
        field: attributes.request
        if: attributes.request != nil
      - type: remove
        field: attributes.source
        if: attributes.source != nil
  journald/openbao:
    units: [openbao]
    resource:
      service.name: openbao
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  # sshd journald → default.otel_logs → verself.host_auth_events MV. Captures
  # every authentication attempt against the host's sshd so failure rate, cert
  # serials, and source-IP geo can be queried alongside the rest of the
  # observability surface. The unit on Ubuntu 24.04 is ssh.service; service.name
  # stays as sshd by convention.
  journald/sshd:
    units: [ssh]
    resource:
      service.name: sshd
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/spire-server:
    units: [spire-server]
    resource:
      service.name: spire-server
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/spire-agent:
    units: [spire-agent]
    resource:
      service.name: spire-agent
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  # Capture lifecycle / handshake messages for every WireGuard tunnel so an
  # operator can confirm `wg-quick@<iface>` came up on each deploy. Driven
  # off the topology so adding a tunnel doesn't require editing this list.
  journald/wireguard:
    units:
{% for tunnel_name, tunnel in (topology_wireguard.tunnels | dictsort) %}
      - wg-quick@{{ tunnel.interface }}
{% endfor %}
    resource:
      service.name: wireguard
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  # App logs for billing-service and sandbox-rental flow through OTLP (via
  # otelslog bridge), not journald. These receivers capture only systemd
  # lifecycle messages (start/stop/crash) and pre-init fatal errors.
  journald/billing-service:
    units: [billing-service]
    resource:
      service.name: billing-service
  journald/sandbox-rental:
    units: [sandbox-rental-service]
    resource:
      service.name: sandbox-rental-service
  journald/sandbox-rental-recurring-worker:
    units: [sandbox-rental-recurring-worker]
    resource:
      service.name: sandbox-rental-recurring-worker
  journald/verself-web:
    units: [verself-web]
    resource:
      service.name: verself-web
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.trace_id
        span_id:
          parse_from: attributes.span_id
        if: attributes.trace_id != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.trace_id
        if: attributes.trace_id != nil
      - type: remove
        field: attributes.span_id
        if: attributes.span_id != nil
  journald/vm-orchestrator:
    units: [vm-orchestrator]
    resource:
      service.name: vm-orchestrator
  journald/forgejo:
    units: [forgejo]
    resource:
      service.name: forgejo
    operators:
      # Forgejo router logs are plain text wrapped in journald metadata.
      # Extract MESSAGE to get the log line itself.
      - type: move
        from: body.MESSAGE
        to: body
  journald/source-code-hosting-service:
    units: [source-code-hosting-service]
    resource:
      service.name: source-code-hosting-service
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/projects-service:
    units: [projects-service]
    resource:
      service.name: projects-service
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/grafana:
    units: [grafana]
    resource:
      service.name: grafana
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/temporal-server:
    units: [temporal-server]
    resource:
      service.name: temporal-server
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        if: 'body != nil and IsMatch(body, "^\\{")'
      - type: severity_parser
        parse_from: attributes.level
        if: attributes.level != nil
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
        if: attributes.msg != nil
      - type: remove
        field: attributes.ts
        if: attributes.ts != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
  journald/bazel-remote:
    units: [bazel-remote]
    resource:
      service.name: bazel-remote
    operators:
      - type: move
        from: body.MESSAGE
        to: body
  journald/verdaccio:
    units: [verdaccio]
    resource:
      service.name: verdaccio
    operators:
      # Verdaccio writes pino JSON to stdout with log.format: json. Parse
      # into attributes, map pino numeric levels to OTel severity, and
      # drop the full req/request objects so auth headers can never reach
      # ClickHouse even if Verdaccio's own pino-redact misses them.
      - type: move
        from: body.MESSAGE
        to: body
      # log.format: json is set in verdaccio's config, so every verdaccio.service
      # line on journald is pino JSON. on_error: send_quiet keeps the entry
      # flowing if a future pre-pino line ever sneaks through.
      - type: json_parser
        parse_from: body
        on_error: send_quiet
        timestamp:
          parse_from: attributes.time
          layout_type: epoch
          layout: ms
      # pino levels: trace=10 debug=20 info=30 warn=40 error=50 fatal=60.
      # Verdaccio adds http=25 for per-request access logs; map it to INFO.
      # stanza's severity_parser ignores dash-range syntax (N-M) for numeric
      # input — list form is the only shape that matches int attributes.
      - type: severity_parser
        parse_from: attributes.level
        if: attributes.level != nil
        mapping:
          debug: [10, 20]
          info: [25, 30]
          warn: 40
          error: 50
          fatal: 60
      - type: move
        from: attributes.msg
        to: body
        if: attributes.msg != nil
      - type: move
        from: attributes.request.method
        to: attributes.http_method
        if: attributes.request != nil
      - type: move
        from: attributes.request.url
        to: attributes.http_url
        if: attributes.request != nil
      - type: move
        from: attributes.status
        to: attributes.http_status
        if: attributes.status != nil
      - type: move
        from: attributes.bytes.out
        to: attributes.http_response_bytes
        if: attributes.bytes != nil
      - type: move
        from: attributes.remoteIP
        to: attributes.client_ip
        if: attributes.remoteIP != nil
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.pid
        if: attributes.pid != nil
      - type: remove
        field: attributes.hostname
        if: attributes.hostname != nil
      - type: remove
        field: attributes.req
        if: attributes.req != nil
      - type: remove
        field: attributes.request
        if: attributes.request != nil
      - type: remove
        field: attributes.bytes
        if: attributes.bytes != nil
  postgresql:
    endpoint: "{{ topology_endpoints.postgresql.endpoints.postgres.address }}"
    username: postgres
    password: "{{ postgresql_admin_password }}"
    databases: [sandbox_rental]
    collection_interval: 10s
    tls:
      insecure: true
  filelog/postgresql:
    include: [{{ postgresql_log_dir }}/postgresql-*.log]
    storage: file_storage
    resource:
      service.name: postgresql
    multiline:
      line_start_pattern: '^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}'
    operators:
      - type: regex_parser
        regex: '^(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d+ \w+) \[(?P<pid>\d+)\]\s*(?:(?P<user>\S+)@(?P<database>\S+)\s+)?(?P<level>\w+):\s+(?P<message>.*)'
        timestamp:
          parse_from: attributes.timestamp
          layout_type: gotime
          layout: "2006-01-02 15:04:05.000 MST"
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          debug: [DEBUG, DEBUG1, DEBUG2, DEBUG3, DEBUG4, DEBUG5]
          info: [INFO, LOG, NOTICE]
          warn: WARNING
          error: [ERROR, FATAL, PANIC]
      - type: move
        from: attributes.message
        to: body
      - type: remove
        field: attributes.timestamp
        if: attributes.timestamp != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
  hostmetrics:
    collection_interval: 1s
    scrapers:
      process:
        include:
          match_type: regexp
          names: ["billing-service", "sandbox-rental.*", "haproxy", "clickhouse.*", "ClickHouse.*", "forgejo.*", "source-code-hosting-service", "projects-service", "grafana.*", "otelcol.*", "node", "verself", "verdaccio", "next-server.*", "npm", "vm-orchestrator.*", "tigerbeetle", "zitadel", "bao", "postgres", "spire-server", "spire-agent", "verself-temporal-server"]
        mute_process_exe_error: true
        mute_process_io_error: true
      cpu: {}
      memory: {}
      load: {}
      filesystem:
        include_fs_types:
          match_type: strict
          fs_types: [ext4, zfs]
      disk: {}
      network: {}
  statsd:
    endpoint: "{{ topology_endpoints.otelcol.endpoints.statsd.address }}"
    aggregation_interval: 10s
  prometheus/openbao:
    config:
      scrape_configs:
        - job_name: openbao
          scrape_interval: 10s
          scheme: https
          metrics_path: /v1/sys/metrics
          params:
            format: [prometheus]
          tls_config:
            insecure_skip_verify: true
          static_configs:
            - targets: ["{{ topology_endpoints.openbao.endpoints.api.address }}"]
  prometheus/temporal:
    config:
      scrape_configs:
        - job_name: temporal
          scrape_interval: 10s
          static_configs:
            - targets: ["{{ topology_endpoints.temporal.endpoints.metrics.address }}"]
  prometheus/bazel-remote:
    config:
      scrape_configs:
        - job_name: bazel-remote
          scrape_interval: 10s
          static_configs:
            - targets: ["{{ topology_endpoints.bazel_remote.endpoints.http.address }}"]
  prometheus/nomad:
    config:
      scrape_configs:
        - job_name: nomad
          scrape_interval: 10s
          metrics_path: /v1/metrics
          params:
            format: [prometheus]
          static_configs:
            - targets: ["{{ topology_endpoints.nomad.endpoints.http.address }}"]
  prometheus/haproxy:
    config:
      scrape_configs:
        - job_name: haproxy
          scrape_interval: 10s
          metrics_path: /metrics
          static_configs:
            - targets: ["{{ topology_endpoints.haproxy.endpoints.metrics.address }}"]

processors:
  batch:
    send_batch_size: 10000
    timeout: 5s
  # Upstream community.general.opentelemetry emits the playbook span named
  # after the playbook file (e.g. "box.yml") and each task span
  # named after the raw task title. Rename to a stable
  # ansible.playbook/ansible.task schema so downstream queries don't have to
  # special-case per-playbook names, and mirror verself.* resource
  # attributes onto span attributes so ansible and service spans share one
  # query shape: SpanAttributes['verself.deploy_id'].
  transform/ansible_spans:
    error_mode: ignore
    trace_statements:
      - context: span
        conditions:
          - resource.attributes["service.name"] == "ansible"
        statements:
          - set(name, "ansible.playbook") where IsMatch(name, ".*\\.ya?ml$")
          - set(name, "ansible.task") where name != "ansible.playbook"
          - set(attributes["verself.deploy_id"], resource.attributes["verself.deploy_id"]) where resource.attributes["verself.deploy_id"] != nil
          - set(attributes["verself.deploy_run_key"], resource.attributes["verself.deploy_run_key"]) where resource.attributes["verself.deploy_run_key"] != nil
          - set(attributes["verself.commit_sha"], resource.attributes["verself.commit_sha"]) where resource.attributes["verself.commit_sha"] != nil
          - set(attributes["verself.branch"], resource.attributes["verself.branch"]) where resource.attributes["verself.branch"] != nil
          - set(attributes["verself.commit_message"], resource.attributes["verself.commit_message"]) where resource.attributes["verself.commit_message"] != nil
          - set(attributes["verself.author"], resource.attributes["verself.author"]) where resource.attributes["verself.author"] != nil
          - set(attributes["verself.dirty"], resource.attributes["verself.dirty"]) where resource.attributes["verself.dirty"] != nil
          - set(attributes["verself.deploy_kind"], resource.attributes["verself.deploy_kind"]) where resource.attributes["verself.deploy_kind"] != nil

exporters:
  clickhouse:
    endpoint: tcp://{{ topology_endpoints.clickhouse.endpoints.native_tls.address }}?secure=true&dial_timeout=10s
    username: {{ otelcol_clickhouse_user }}
    database: default
    logs_table_name: otel_logs
    traces_table_name: otel_traces
    create_schema: false
    # The collector only wires its TLS client when cert/key are set; keep the
    # full mTLS tuple here so ClickHouse never silently falls back to plaintext auth.
    # spiffe-helper rotates the SVID on disk every ~30 minutes; reload_interval
    # makes the exporter re-read cert/key/ca so the in-memory TLS material never
    # outlives the SVID lifetime and connections don't fail with expired cert.
    tls:
      ca_file: {{ otelcol_clickhouse_server_ca_path }}
      cert_file: {{ otelcol_clickhouse_spiffe_dir }}/svid.pem
      key_file: {{ otelcol_clickhouse_spiffe_dir }}/svid_key.pem
      reload_interval: 60s

extensions:
  health_check:
    endpoint: 127.0.0.1:13133  # not in topology artifacts — no cross-service consumers
  file_storage:
    directory: /var/lib/otelcol/storage

service:
  extensions: [health_check, file_storage]
  pipelines:
    logs:
      receivers: [otlp, journald/haproxy, journald/billing-service, journald/sandbox-rental, journald/sandbox-rental-recurring-worker, journald/verself-web, journald/zitadel, journald/openbao, journald/sshd, journald/spire-server, journald/spire-agent, journald/vm-orchestrator, journald/forgejo, journald/source-code-hosting-service, journald/projects-service, journald/grafana, journald/temporal-server, journald/verdaccio, journald/wireguard, journald/bazel-remote, filelog/postgresql]
      processors: [batch]
      exporters: [clickhouse]
    traces:
      receivers: [otlp]
      processors: [transform/ansible_spans, batch]
      exporters: [clickhouse]
    metrics:
      receivers: [otlp, hostmetrics, postgresql, statsd, prometheus/openbao, prometheus/temporal, prometheus/bazel-remote, prometheus/nomad, prometheus/haproxy]
      processors: [batch]
      exporters: [clickhouse]
