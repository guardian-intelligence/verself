<clickhouse>
    <listen_host>{{ topology_endpoints.clickhouse.host }}</listen_host>
    <tcp_port_secure>{{ topology_endpoints.clickhouse.endpoints.native_tls.port }}</tcp_port_secure>

    <path>{{ clickhouse_data_path }}/</path>
    <tmp_path>{{ clickhouse_data_path }}/tmp/</tmp_path>
    <user_files_path>{{ clickhouse_data_path }}/user_files/</user_files_path>
    <format_schema_path>{{ clickhouse_data_path }}/format_schemas/</format_schema_path>
    <access_control_path>{{ clickhouse_data_path }}/access/</access_control_path>

    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>100M</size>
        <count>3</count>
    </logger>

    <openSSL>
        <server>
            <certificateFile>/etc/clickhouse-server/tls/server-cert.pem</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/tls/server-key.pem</privateKeyFile>
            <!-- strict is required for certificate-authenticated users; relaxed only works for testing. -->
            <verificationMode>strict</verificationMode>
            <caConfig>{{ clickhouse_server_spiffe_dir }}/bundle.pem</caConfig>
            <cacheSessions>true</cacheSessions>
            <disableProtocols>sslv2,sslv3</disableProtocols>
            <preferServerCiphers>true</preferServerCiphers>
        </server>
    </openSSL>

    <!-- Default profiles and users (required when running standalone without /etc/clickhouse-server/users.xml) -->
    <profiles>
        <default/>
    </profiles>

    <users>
        <!-- Config-defined users default to ALL ... WITH GRANT OPTION unless explicit grants are set; clickhouse_operator uses that bootstrap path. -->
        <{{ clickhouse_operator_db_user }}>
            <ssl_certificates>
                <subject_alt_name>URI:{{ spire_clickhouse_operator_id }}</subject_alt_name>
            </ssl_certificates>
            <networks>
                <ip>127.0.0.1</ip>
                <ip>::1</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
        </{{ clickhouse_operator_db_user }}>
    </users>

    <!-- Query logging: populates system.query_log for east/west traffic visibility -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_time)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
