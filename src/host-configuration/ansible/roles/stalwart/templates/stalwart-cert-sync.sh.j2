#!/bin/bash
# Sync Caddy's ACME-issued TLS certificate for {{ stalwart_domain }} to Stalwart.
# Called by stalwart-cert-sync.timer every 12 hours and on boot.
set -euo pipefail

DOMAIN="{{ stalwart_domain }}"
CERT_DIR="{{ stalwart_tls_cert_dir }}"

# Caddy stores certs under its data directory, keyed by ACME directory URL.
# Try both Let's Encrypt production and ZeroSSL (Caddy's fallback).
CADDY_BASE="{{ stalwart_caddy_cert_base }}"
FOUND=""

for acme_dir in "$CADDY_BASE"/*/; do
    cert="$acme_dir$DOMAIN/$DOMAIN.crt"
    key="$acme_dir$DOMAIN/$DOMAIN.key"
    if [ -f "$cert" ] && [ -f "$key" ]; then
        FOUND="$acme_dir"
        break
    fi
done

if [ -z "$FOUND" ]; then
    echo "No cert found for $DOMAIN in $CADDY_BASE — skipping sync"
    exit 0
fi

SRC_CERT="${FOUND}${DOMAIN}/${DOMAIN}.crt"
SRC_KEY="${FOUND}${DOMAIN}/${DOMAIN}.key"
DST_CERT="${CERT_DIR}/cert.pem"
DST_KEY="${CERT_DIR}/key.pem"

# Only copy if source is newer than destination
if [ ! -f "$DST_CERT" ] || [ "$SRC_CERT" -nt "$DST_CERT" ]; then
    cp "$SRC_CERT" "$DST_CERT"
    cp "$SRC_KEY" "$DST_KEY"
    chown root:stalwart "$DST_CERT" "$DST_KEY"
    chmod 640 "$DST_CERT" "$DST_KEY"
    echo "Certs synced for $DOMAIN — reloading Stalwart"
    systemctl reload stalwart.service
else
    echo "Certs unchanged for $DOMAIN"
fi
