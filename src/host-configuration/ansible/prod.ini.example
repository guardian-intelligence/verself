# Example inventory. Copy to <site>.ini and populate with real IPs.
# Terraform outputs can generate this automatically.

[workers]
# vs-prod-w0 ansible_host=203.0.113.10
# vs-prod-w1 ansible_host=203.0.113.11
# vs-prod-w2 ansible_host=203.0.113.12

[infra]
# vs-prod-i0 ansible_host=203.0.113.20
# vs-prod-i1 ansible_host=203.0.113.21
# vs-prod-i2 ansible_host=203.0.113.22

[all:vars]
ansible_user=ubuntu
ansible_python_interpreter=/usr/bin/python3
