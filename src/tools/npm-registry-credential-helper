#!/usr/bin/env python3
import json
import os
import sys
from urllib.parse import urlparse


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] != "get":
        print("expected credential-helper command: get", file=sys.stderr)
        return 1

    try:
        request = json.load(sys.stdin)
    except json.JSONDecodeError as err:
        print(f"invalid credential-helper request: {err}", file=sys.stderr)
        return 1

    uri = request.get("uri", "")
    if urlparse(uri).hostname != "npm.verself.sh":
        json.dump({"headers": {}}, sys.stdout)
        return 0

    token = os.environ.get("VERSELF_NPM_REGISTRY_TOKEN", "").strip()
    if not token:
        print("VERSELF_NPM_REGISTRY_TOKEN is required for npm.verself.sh", file=sys.stderr)
        return 1

    json.dump({"headers": {"Authorization": [f"Bearer {token}"]}}, sys.stdout)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
