load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "verself-deploy_lib",
    srcs = [
        "artifacts.go",
        "bazel.go",
        "evidence.go",
        "main.go",
        "nomad.go",
        "plan.go",
        "run.go",
        "safeconv.go",
    ],
    importpath = "github.com/verself/deployment-tools/cmd/verself-deploy",
    visibility = ["//visibility:private"],
    deps = [
        "//src/tools/deployment/internal/bazelbuild",
        "//src/tools/deployment/internal/deploydb",
        "//src/tools/deployment/internal/deploymodel",
        "//src/tools/deployment/internal/garage",
        "//src/tools/deployment/internal/identity",
        "//src/tools/deployment/internal/nomadclient",
        "//src/tools/deployment/internal/runtime",
        "//src/tools/deployment/internal/sshtun",
        "@com_github_hashicorp_nomad_api//:api",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

go_binary(
    name = "verself-deploy",
    embed = [":verself-deploy_lib"],
    visibility = ["//visibility:public"],
)
