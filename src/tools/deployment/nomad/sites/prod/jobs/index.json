{
  "artifact_delivery": {
    "kind": "garage_s3_private_origin",
    "bucket": "nomad-artifacts",
    "key_prefix": "sha256",
    "getter_source_prefix": "s3::https://artifacts.internal.verself.sh:9443/nomad-artifacts",
    "getter_options": {
      "region": "garage"
    },
    "getter_credentials": {
      "source": "host_environment",
      "environment_file": "/etc/nomad/nomad-artifacts.env",
      "access_key_id_env": "AWS_ACCESS_KEY_ID",
      "secret_access_key_env": "AWS_SECRET_ACCESS_KEY"
    },
    "publisher_credentials": {
      "source": "controller_environment",
      "environment_file": "/etc/garage/nomad-artifacts/publisher.env",
      "access_key_id_env": "VERSELF_NOMAD_ARTIFACTS_AWS_ACCESS_KEY_ID",
      "secret_access_key_env": "VERSELF_NOMAD_ARTIFACTS_AWS_SECRET_ACCESS_KEY"
    },
    "checksum_algorithm": "sha256",
    "public": false,
    "origin": {
      "scheme": "https",
      "hostname": "artifacts.internal.verself.sh",
      "port": 9443,
      "placement": "node_local",
      "resolution": "per_node_hosts_file",
      "listen_host": "127.0.0.1",
      "public_dns": false,
      "public_ingress": false,
      "ca_bundle_path": "/etc/verself/pki/nomad-artifacts-ca.pem"
    }
  },
  "nomad_addr": "http://127.0.0.1:4646",
  "components": [
    {
      "component": "billing",
      "job_id": "billing",
      "bazel_label": "//src/services/billing-service/cmd/billing-service:billing-service",
      "output": "billing-service",
      "depends_on": [
        "secrets-service"
      ],
      "artifacts": [
        {
          "bazel_label": "//src/services/billing-service/cmd/billing-service:billing-service",
          "nomad_artifact_label": "//src/services/billing-service/cmd/billing-service:billing-service_nomad_artifact",
          "output": "billing-service"
        }
      ]
    },
    {
      "component": "sandbox_rental",
      "job_id": "sandbox-rental",
      "bazel_label": "//src/services/sandbox-rental-service/cmd/sandbox-rental-service:sandbox-rental-service",
      "output": "sandbox-rental-service",
      "depends_on": [
        "secrets-service",
        "source-code-hosting-service"
      ],
      "artifacts": [
        {
          "bazel_label": "//src/services/sandbox-rental-service/cmd/sandbox-rental-service:sandbox-rental-service",
          "nomad_artifact_label": "//src/services/sandbox-rental-service/cmd/sandbox-rental-service:sandbox-rental-service_nomad_artifact",
          "output": "sandbox-rental-service"
        },
        {
          "bazel_label": "//src/services/sandbox-rental-service/cmd/sandbox-rental-recurring-worker:sandbox-rental-recurring-worker",
          "nomad_artifact_label": "//src/services/sandbox-rental-service/cmd/sandbox-rental-recurring-worker:sandbox-rental-recurring-worker_nomad_artifact",
          "output": "sandbox-rental-recurring-worker"
        }
      ]
    },
    {
      "component": "iam_service",
      "job_id": "iam-service",
      "bazel_label": "//src/services/iam-service/cmd/iam-service:iam-service",
      "output": "iam-service",
      "artifacts": [
        {
          "bazel_label": "//src/services/iam-service/cmd/iam-service:iam-service",
          "nomad_artifact_label": "//src/services/iam-service/cmd/iam-service:iam-service_nomad_artifact",
          "output": "iam-service"
