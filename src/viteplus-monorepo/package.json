{
  "name": "@verself/viteplus-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run @verself/verself-web#dev",
    "generate": "vp run -r generate",
    "check": "vp check",
    "typecheck": "vp run -r typecheck",
    "test": "vp test run",
    "build": "vp run -r build",
    "ready": "vp check && vp test run && vp run -r typecheck && vp run -r build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ],
    "packageExtensions": {
      "@voidzero-dev/vite-plus-core@*": {
        "dependencies": {
          "picomatch": "4.0.4"
        }
      }
    },
    "patchedDependencies": {
      "srvx@0.11.15": "patches/srvx@0.11.15.patch"
    }
  }
}
