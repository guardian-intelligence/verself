{
  "name": "@forge-metal/mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "start": "node --import ./instrumentation.mts .output/server/index.mjs",
    "generate": "vp exec openapi-ts -i ../../../mailbox-service/openapi/openapi-3.1.yaml -o src/__generated/mailbox-api -p @hey-api/typescript @hey-api/sdk valibot && vp exec node ../../scripts/mark-generated-ts-nocheck.mjs src/__generated/mailbox-api && vp fmt src/__generated/mailbox-api --write",
    "test:e2e": "vp exec playwright test",
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@forge-metal/auth-web": "workspace:*",
    "@forge-metal/nitro-plugins": "workspace:*",
    "@forge-metal/ui": "workspace:*",
    "@forge-metal/web-env": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@tanstack/electric-db-collection": "catalog:",
    "@tanstack/query-db-collection": "catalog:",
    "@tanstack/react-db": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "dompurify": "^3.2.6",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "catalog:",
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/dompurify": "^3.2.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
