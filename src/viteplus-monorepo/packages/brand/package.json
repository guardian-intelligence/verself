{
  "name": "@verself/brand",
  "version": "0.1.0",
  "private": true,
  "description": "Guardian Intelligence brand system: SVG marks (Wings/Lockup/Favicon), wordmark variants, and tokens. Deliberately separate from @verself/ui (shadcn) so brand assets evolve on their own cadence.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./tokens": {
      "types": "./src/tokens.ts",
      "default": "./src/tokens.ts"
    },
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
