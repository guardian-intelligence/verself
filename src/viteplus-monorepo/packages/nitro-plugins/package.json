{
  "name": "@verself/nitro-plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Nitro plugins and middleware for TanStack Start apps.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./observability-plugin": "./dist/observability-plugin.mjs",
    "./otel": "./dist/otel.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack src/index.ts src/observability-plugin.ts src/otel.ts --dts",
    "dev": "vp pack src/index.ts src/observability-plugin.ts src/otel.ts --dts --watch",
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-node": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "nitro": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "nitro": "^3.0.0"
  }
}
