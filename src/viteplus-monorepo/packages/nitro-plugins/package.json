{
  "name": "@verself/nitro-plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Server-only Nitro plugin + OpenTelemetry preload, consumed source-first by the apps that bundle them.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./observability-plugin": {
      "types": "./src/observability-plugin.ts",
      "node": "./src/observability-plugin.ts",
      "default": "./src/server-only.ts"
    },
    "./otel": {
      "types": "./src/otel.ts",
      "node": "./src/otel.ts",
      "default": "./src/server-only.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/instrumentation-http": "catalog:",
    "@opentelemetry/instrumentation-undici": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "nitro": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "nitro": "^3.0.0"
  }
}
