load("//src/viteplus-monorepo:viteplus_rules.bzl", "viteplus_packed_package")

package(default_visibility = ["//visibility:public"])

viteplus_packed_package(
    srcs = [
        "package.json",
        "schema/**/*",
        "src/**/*",
        "tsconfig.json",
    ],
    entries = [
        "src/index.ts",
        "src/config.ts",
        "src/isomorphic.ts",
        "src/react.ts",
        "src/components/index.ts",
    ],
    npm_name = "@verself/auth-web",
)
