{
  "name": "@forge-metal/auth-web",
  "version": "0.1.0",
  "private": true,
  "description": "Shared server-owned auth helpers for TanStack Start apps.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./server-fns": {
      "types": "./src/server-fns.ts",
      "default": "./src/server-fns.ts"
    },
    "./shared": {
      "types": "./src/shared.ts",
      "default": "./src/shared.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack src/index.ts src/config.ts src/server-fns.ts src/shared.ts src/react.ts",
    "dev": "vp pack src/index.ts src/config.ts src/server-fns.ts src/shared.ts src/react.ts --watch",
    "test": "cd ../.. && vp test run packages/auth-web/src/index.test.ts",
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "jose": "catalog:",
    "postgres": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
