{
  "name": "@verself/auth-web",
  "version": "0.1.0",
  "private": true,
  "description": "Shared auth helpers for TanStack Start apps. Source-only — apps bundle the .ts directly; subpath exports gate server-only code from the client.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/isomorphic.ts",
      "default": "./src/isomorphic.ts"
    },
    "./server": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./isomorphic": {
      "types": "./src/isomorphic.ts",
      "default": "./src/isomorphic.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "cd ../.. && vp test run packages/auth-web/src",
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@verself/ui": "workspace:*",
    "jose": "catalog:",
    "lucide-react": "catalog:",
    "postgres": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "fast-check": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
