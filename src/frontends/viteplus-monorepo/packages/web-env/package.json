{
  "name": "@verself/web-env",
  "version": "0.1.0",
  "private": true,
  "description": "Validated env parsing and origin derivation for verself web apps. Source-only — apps bundle the .ts directly.",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "vp exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/electric-db-collection": "catalog:",
    "@tanstack/react-db": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
