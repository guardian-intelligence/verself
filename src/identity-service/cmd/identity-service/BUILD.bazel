load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("//src/deployment-tools/nomad:artifact.bzl", "nomad_binary_artifact")

go_library(
    name = "identity-service_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/identity-service/cmd/identity-service",
    visibility = ["//visibility:private"],
    deps = [
        "//src/auth-middleware",
        "//src/auth-middleware/workload",
        "//src/service-runtime/go/envconfig",
        "//src/service-runtime/go/httpserver",
        "//src/identity-service/internal/api",
        "//src/identity-service/internal/identity",
        "//src/identity-service/internal/zitadel",
        "//src/identity-service/migrations",
        "//src/observability/go/otel",
        "@com_github_clickhouse_clickhouse_go_v2//:clickhouse-go",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
    ],
)

go_binary(
    name = "identity-service",
    embed = [":identity-service_lib"],
    visibility = ["//visibility:public"],
)

nomad_binary_artifact(
    name = "identity-service_nomad_artifact",
    binary = ":identity-service",
    output = "identity-service",
)

exports_files(["nomad-overrides.json"])
