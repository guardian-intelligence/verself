load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "api",
    srcs = [
        "api.go",
        "auth.go",
        "mail.go",
        "operator.go",
        "status.go",
    ],
    importpath = "github.com/verself/mailbox-service/internal/api",
    visibility = ["//src/mailbox-service:__subpackages__"],
    deps = [
        "//src/auth-middleware",
        "//src/domain-transfer-objects/go:dto",
        "//src/mailbox-service/internal/app",
        "//src/mailbox-service/internal/jmap",
        "//src/mailbox-service/internal/mailstore",
        "//src/mailbox-service/internal/sync",
        "@com_github_danielgtaylor_huma_v2//:huma",
        "@com_github_danielgtaylor_huma_v2//adapters/humago",
    ],
)

alias(
    name = "go_default_library",
    actual = ":api",
    visibility = ["//src/mailbox-service:__subpackages__"],
)
