load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("//src/cue-renderer/nomad:artifact.bzl", "nomad_binary_artifact")

go_library(
    name = "mailbox-service_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/mailbox-service/cmd/mailbox-service",
    visibility = ["//visibility:private"],
    deps = [
        "//src/auth-middleware",
        "//src/auth-middleware/workload",
        "//src/envconfig",
        "//src/httpserver",
        "//src/mailbox-service/internal/api",
        "//src/mailbox-service/internal/app",
        "//src/mailbox-service/internal/forwarder",
        "//src/mailbox-service/internal/mailstore",
        "//src/mailbox-service/internal/sessionproxy",
        "//src/mailbox-service/internal/sync",
        "//src/mailbox-service/migrations",
        "//src/otel",
        "//src/secrets-service/client",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
    ],
)

go_binary(
    name = "mailbox-service",
    embed = [":mailbox-service_lib"],
    visibility = ["//visibility:public"],
)

nomad_binary_artifact(
    name = "mailbox-service_nomad_artifact",
    binary = ":mailbox-service",
    output = "mailbox-service",
)
