load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("//tools/nomad:artifact.bzl", "nomad_binary_artifact")

go_library(
    name = "sandbox-rental-recurring-worker_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/sandbox-rental-service/cmd/sandbox-rental-recurring-worker",
    visibility = ["//visibility:private"],
    deps = [
        "//src/auth-middleware/workload",
        "//src/envconfig",
        "//src/otel",
        "//src/sandbox-rental-service/internal/recurring",
        "//src/sandbox-rental-service/internal/sourceworkflow",
        "//src/temporal-platform/sdkclient",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@io_temporal_go_sdk//worker",
    ],
)

go_binary(
    name = "sandbox-rental-recurring-worker",
    embed = [":sandbox-rental-recurring-worker_lib"],
    visibility = ["//visibility:public"],
)

nomad_binary_artifact(
    name = "sandbox-rental-recurring-worker_nomad_artifact",
    binary = ":sandbox-rental-recurring-worker",
    output = "sandbox-rental-recurring-worker",
)
