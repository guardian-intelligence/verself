load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "scheduler",
    srcs = ["runtime.go"],
    importpath = "github.com/verself/sandbox-rental-service/internal/scheduler",
    visibility = ["//src/sandbox-rental-service:__subpackages__"],
    deps = [
        "@com_github_jackc_pgx_v5//:pgx",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@com_github_riverqueue_river//:river",
        "@com_github_riverqueue_river_riverdriver_riverpgxv5//:riverpgxv5",
        "@com_github_riverqueue_river_rivertype//:rivertype",
        "@com_github_riverqueue_rivercontrib_otelriver//:otelriver",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//propagation",
    ],
)

alias(
    name = "go_default_library",
    actual = ":scheduler",
    visibility = ["//src/sandbox-rental-service:__subpackages__"],
)
