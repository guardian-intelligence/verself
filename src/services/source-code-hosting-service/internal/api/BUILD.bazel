load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "api",
    srcs = [
        "dto.go",
        "errors.go",
        "format.go",
        "git_http.go",
        "openapi.go",
        "policy.go",
        "routes.go",
        "safeconv.go",
    ],
    importpath = "github.com/verself/source-code-hosting-service/internal/api",
    visibility = ["//src/services/source-code-hosting-service:__subpackages__"],
    deps = [
        "//src/domain-transfer-objects/go:dto",
        "//src/services/service-runtime/go/auth",
        "//src/services/service-runtime/go/workload",
        "//src/services/source-code-hosting-service/internal/source",
        "@com_github_danielgtaylor_huma_v2//:huma",
        "@com_github_danielgtaylor_huma_v2//adapters/humago",
        "@com_github_google_uuid//:uuid",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

alias(
    name = "go_default_library",
    actual = ":api",
    visibility = ["//src/services/source-code-hosting-service:__subpackages__"],
)
