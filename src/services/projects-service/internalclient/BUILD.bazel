load("//bazel:openapi_codegen.bzl", "verself_oapi_go_client")

verself_oapi_go_client(
    name = "internalclient",
    importpath = "github.com/verself/projects-service/internalclient",
    package = "projectsinternalclient",
    response_type_suffix = "HTTPResponse",
    spec = "//src/services/projects-service/openapi:internal-openapi-3.0.yaml",
    deps = [
        "@com_github_oapi_codegen_runtime//:runtime",
        "@com_github_oapi_codegen_runtime//types",
    ],
)

alias(
    name = "go_default_library",
    actual = ":internalclient",
    visibility = ["//visibility:public"],
)
