load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "app",
    srcs = [
        "app.go",
        "mail.go",
    ],
    importpath = "github.com/verself/mailbox-service/internal/app",
    visibility = ["//src/services/mailbox-service:__subpackages__"],
    deps = [
        "//src/services/mailbox-service/internal/forwarder",
        "//src/services/mailbox-service/internal/jmap",
        "//src/services/mailbox-service/internal/mailstore",
        "//src/services/mailbox-service/internal/sessionproxy",
        "//src/services/mailbox-service/internal/sync",
    ],
)

alias(
    name = "go_default_library",
    actual = ":app",
    visibility = ["//src/services/mailbox-service:__subpackages__"],
)
