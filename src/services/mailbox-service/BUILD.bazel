# gazelle:prefix github.com/verself/mailbox-service

load("//src/tools/deployment/nomad:component.bzl", "nomad_component")
load("//src/tools/deployment/spire:identity.bzl", "spire_identity")

spire_identity(
    name = "spiffe_identity",
    component = "mailbox_service",
    entry_id = "verself-mailbox-service",
    key = "mailbox_service.default",
    path = "/svc/mailbox-service",
    user = "mailbox_service",
    visibility = ["//src/host-configuration:__pkg__"],
