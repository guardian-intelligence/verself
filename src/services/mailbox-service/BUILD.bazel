nomad_component(
    name = "nomad_component",
    artifacts = {
        "//src/services/mailbox-service/cmd/mailbox-service:mailbox-service_nomad_artifact": "mailbox-service",
    },
    component = "mailbox_service",
    depends_on = ["secrets-service"],
    job_id = "mailbox-service",
    job_spec = "nomad.hcl",
    visibility = ["//src/tools/deployment/nomad:__pkg__"],
