load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "secrets",
    srcs = [
        "audit_context.go",
        "baostore.go",
        "credentials.go",
        "raw_token.go",
        "safeconv.go",
        "service.go",
    ],
    importpath = "github.com/verself/secrets-service/internal/secrets",
    visibility = ["//src/services/secrets-service:__subpackages__"],
    deps = [
        "//src/services/billing-service/client",
        "//src/services/service-runtime/go/workload",
        "@com_github_google_uuid//:uuid",
        "@com_github_spiffe_go_spiffe_v2//spiffeid",
        "@com_github_spiffe_go_spiffe_v2//workloadapi",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
    ],
)

alias(
    name = "go_default_library",
    actual = ":secrets",
    visibility = ["//src/services/secrets-service:__subpackages__"],
)
