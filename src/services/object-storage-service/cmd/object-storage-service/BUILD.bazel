load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("//src/tools/deployment/nomad:artifact.bzl", "nomad_binary_artifact")

go_library(
    name = "object-storage-service_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/object-storage-service/cmd/object-storage-service",
    visibility = ["//visibility:private"],
    deps = [
        "//src/services/object-storage-service/internal/api",
        "//src/services/object-storage-service/internal/objectstorage",
        "//src/services/object-storage-service/migrations",
        "//src/services/service-runtime/go/envconfig",
        "//src/services/service-runtime/go/httpserver",
        "//src/services/service-runtime/go/workload",
        "//src/tools/observability/go/otel",
        "@com_github_clickhouse_clickhouse_go_v2//:clickhouse-go",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@com_github_spiffe_go_spiffe_v2//spiffetls/tlsconfig",
        "@com_github_spiffe_go_spiffe_v2//workloadapi",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
    ],
)

go_binary(
    name = "object-storage-service",
    embed = [":object-storage-service_lib"],
    visibility = ["//visibility:public"],
)

nomad_binary_artifact(
    name = "object-storage-service_nomad_artifact",
    binary = ":object-storage-service",
    output = "object-storage-service",
)
