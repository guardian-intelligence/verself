# Zitadel first-instance bootstrap.
# Managed by Ansible — do not edit manually.
# Passed to `zitadel setup --steps` on first init only.

FirstInstance:
  InstanceName: verself
  PatPath: "{{ zitadel_config_dir }}/admin.pat"
  Org:
    Name: Guardian Intelligence LLC
    Human:
      UserName: ceo
      FirstName: CEO
      LastName: Operator
      Email:
        Address: "ceo@{{ verself_domain }}"
        Verified: true
      Password: "{{ zitadel_admin_password }}"
      PasswordChangeRequired: false
    Machine:
      Machine:
        Username: verself-admin
        Name: verself admin
      Pat:
        ExpirationDate: "2099-01-01T00:00:00Z"
