# Stalwart Mail Server configuration.
# Managed by Ansible — do not edit manually.
# Receive-only: no outbound relay, all delivery is local.

[server]
hostname = "{{ stalwart_domain }}"
max-connections = 256

# --- Listeners ---

[server.listener."smtp"]
bind = ["0.0.0.0:{{ topology_endpoints.stalwart.endpoints.smtp.port }}"]
protocol = "smtp"
tls.implicit = false

[server.listener."http"]
bind = ["{{ topology_endpoints.stalwart.endpoints.http.address }}"]
protocol = "http"
tls.implicit = false

# --- TLS ---
# Certs synced from Caddy's ACME storage by stalwart-cert-sync.timer.
# Self-signed placeholder deployed on first run; real cert replaces it
# after Caddy obtains the ACME cert for {{ stalwart_domain }}.

[certificate."default"]
cert = "%{file:{{ stalwart_tls_cert_dir }}/cert.pem}%"
private-key = "%{file:{{ stalwart_tls_cert_dir }}/key.pem}%"
default = true

# --- Storage ---

[config]
local-keys = [
    "store.*",
    "directory.*",
    "tracer.*",
    "!server.blocked-ip.*",
    "!server.allowed-ip.*",
    "server.*",
    "authentication.fallback-admin.*",
    "cluster.*",
    "config.local-keys.*",
    "storage.data",
    "storage.blob",
    "storage.lookup",
    "storage.fts",
    "storage.directory",
    "certificate.*",
    "http.*",
    "webadmin.*",
    "spam-filter.resource",
]

[http]
url = "'https://{{ stalwart_domain }}'"
use-x-forwarded = true
allowed-endpoint.0.if = "starts_with(url_path, '/api') && remote_ip != '127.0.0.1'"
allowed-endpoint.0.then = "404"
allowed-endpoint.1.else = "200"

[webadmin]
path = "{{ stalwart_data_dir }}"
resource = "file://{{ stalwart_webadmin_local_path }}"

[spam-filter]
resource = "file://{{ stalwart_spam_filter_local_path }}"

[store."postgresql"]
type = "postgresql"
# Unix-socket peer auth. Stalwart runs as the `stalwart` OS user; pg_ident.conf
# maps that to the `stalwart` PG role. No password is sent; the role has no
# password set, so TCP/SCRAM auth against this role is rejected by PostgreSQL.
host = "/var/run/postgresql"
database = "stalwart"
user = "stalwart"
timeout = "15s"

[store."postgresql".pool]
max-connections = 10

[storage]
data = "postgresql"
blob = "postgresql"
fts = "postgresql"
lookup = "postgresql"
directory = "internal"

# --- Authentication ---

[directory."internal"]
type = "internal"
store = "postgresql"

# Fallback admin for Management API bootstrap.
[authentication.fallback-admin]
user = "admin"
secret = "%{file:/run/credentials/stalwart.service/admin-password}%"

# --- Settings below are local-only (TOML bootstrap) ---
# session.*, remote.*, queue.*, metrics.* must be pushed via the Settings API
# after startup — see tasks/settings.yml. Stalwart v0.15+ enforces this split.
# We explicitly pin selected http.* keys locally via config.local-keys because
# JMAP session URL generation depends on the expression parsing at startup.
# https://stalw.art/docs/configuration/overview/#local-and-database-settings

# --- Telemetry: OpenTelemetry (tracer is local-only, metrics is database) ---

[tracer."otel"]
type = "open-telemetry"
transport = "grpc"
endpoint = "http://{{ topology_endpoints.otelcol.endpoints.otlp_grpc.address }}"
level = "info"
enable = true
enable.log-exporter = true
enable.span-exporter = true
