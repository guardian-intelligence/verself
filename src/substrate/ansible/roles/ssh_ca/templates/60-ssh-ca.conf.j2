# Managed by Ansible — ssh_ca role.
# sshd drop-in for OpenBao-issued SSH certificates.
# Source of truth: topology_ssh_ca in group_vars/all/generated/ops.yml

# CA pubkey: any cert signed by this key is admissible. The CA private
# key lives in OpenBao's SSH secrets engine; sshd never sees it.
TrustedUserCAKeys {{ topology_ssh_ca.ca_pubkey_path }}

# Per-user principals allowlist. The cert's `valid_principals` set must
# intersect this file or sshd rejects the connection.
AuthorizedPrincipalsFile {{ topology_ssh_ca.principals_file }}

# Static keys are dead. AuthorizedKeysFile=none disables the legacy
# ~/.ssh/authorized_keys path entirely; sshd no longer consults the file.
# Anything written there (by an agent or by Latitude.sh's provisioning)
# is inert. The only way to authenticate is to present a cert this CA
# signed.
AuthorizedKeysFile none

# Bind only to the wg-ops mesh interface. Combined with the nftables
# drop on enp6s0:22, this removes :22 from the public internet attack
# surface — operators must be on the WireGuard mesh to even reach the
# listener. The wg-quick@wg-ops.service systemd drop-in (installed by
# the ssh_ca role) ensures sshd starts only after the WG interface is
# up at boot, so a reboot can't strand sshd binding 10.66.66.1 before
# the IP exists.
ListenAddress {{ topology_wireguard.tunnels.ops.address }}
