load("//src/substrate/vm-orchestrator/guest-images:guest_image.bzl", "toolchain_ext4_image")

genrule(
    name = "profile-actions-runner",
    outs = ["profile-actions-runner.generated"],
    cmd = "printf '%s\\n' 'export RUNNER_TOOL_CACHE=/opt/hostedtoolcache' 'export AGENT_TOOLSDIRECTORY=/opt/hostedtoolcache' > $@",
)

# gh-actions-runner.ext4 — toolchain image mounted read-only at
# /opt/actions-runner inside the guest. Carries the upstream GitHub
# Actions runner tarball plus an etc-overlay/ tree that vm-bridge
# copies into /etc at lease boot:
#
#   etc-overlay/passwd|group|shadow         add the runner@1000 user
#                                           (sourced from the shared
#                                            //runner-overlay-common
#                                            filegroup)
#   etc-overlay/sudoers.d/runner-nopasswd   NOPASSWD sudo for runner
#   etc-overlay/profile.d/...               toolcache + tools env vars
#                                           (RUNNER_TOOL_CACHE,
#                                            AGENT_TOOLSDIRECTORY)
#
# The .verself-writable-overlays manifest tells vm-bridge to tmpfs-mount
# _work/_diag/_temp on top of the read-only base so the runner can write
# its scratch dirs without poisoning the shared image.
#
# Sized at 1024 MiB; upstream runner tarball is ~150 MiB extracted, the
# overlay is a few KiB, so this leaves comfortable headroom for runner
# version bumps without resizing.
toolchain_ext4_image(
    name = "gh-actions-runner",
    empty_dirs = [
        "_diag",
        "_temp",
        "_work",
    ],
    files = {
        "etc-overlay/passwd": "//src/substrate/vm-orchestrator/guest-images/runner-overlay-common:passwd",
        "etc-overlay/group": "//src/substrate/vm-orchestrator/guest-images/runner-overlay-common:group",
        "etc-overlay/shadow": "//src/substrate/vm-orchestrator/guest-images/runner-overlay-common:shadow",
        "etc-overlay/sudoers.d/runner-nopasswd": "//src/substrate/vm-orchestrator/guest-images/runner-overlay-common:sudoers-runner-nopasswd",
        "etc-overlay/profile.d/verself-actions-runner.sh": ":profile-actions-runner",
        ".verself-writable-overlays": ":writable-overlays",
    },
    label = "ghactions",
    size_mib = 1024,
    tarball = "@guest_image_github_actions_runner//file",
)

exports_files([
    "writable-overlays",
])
