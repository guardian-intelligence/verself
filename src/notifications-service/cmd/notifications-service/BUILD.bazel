load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "notifications-service_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/notifications-service/cmd/notifications-service",
    visibility = ["//visibility:private"],
    deps = [
        "//src/auth-middleware",
        "//src/auth-middleware/workload",
        "//src/envconfig",
        "//src/httpserver",
        "//src/notifications-service/internal/api",
        "//src/notifications-service/internal/notifications",
        "//src/notifications-service/migrations",
        "//src/otel",
        "//src/pgmigrate",
        "@com_github_clickhouse_clickhouse_go_v2//:clickhouse-go",
        "@com_github_jackc_pgx_v5//pgxpool",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
    ],
)

go_binary(
    name = "notifications-service",
    embed = [":notifications-service_lib"],
    visibility = ["//visibility:public"],
)
