# Managed by Ansible — base role
# Drop-in hardening for sshd. Overrides defaults from sshd_config.
# Recovery: Latitude.sh IPMI/KVM console.

PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
MaxAuthTries 3
X11Forwarding no

# LogLevel INFO is the default; pin it explicitly so a future change can't
# silently bump to DEBUG/DEBUG2/DEBUG3, which makes sshd log session-setup
# internals (PAM module trace, channel multiplexing, key-exchange) that
# could carry credential-shaped strings into journald and onward into
# verself.host_auth_events. INFO records "who attempted what from where"
# without dumping protocol internals.
LogLevel INFO

# Concurrency: multiple operator agents multiplex many channels through one
# ControlMaster TCP session; each channel counts against MaxSessions. Default
# (10) was too low for the agent fleet; 3 was catastrophic. MaxStartups loosened
# for connection bursts during parallel playbook runs.
MaxSessions 30
MaxStartups 30:50:200
LoginGraceTime 30

# Server-side liveness: probe every 60s, drop after 3 misses so dead TCP
# sessions release their MaxSessions slot instead of squatting until the kernel
# notices.
ClientAliveInterval 60
ClientAliveCountMax 3
TCPKeepAlive yes
