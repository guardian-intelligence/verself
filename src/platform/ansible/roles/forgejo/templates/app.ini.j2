; Forgejo configuration — managed by Ansible.
; https://forgejo.org/docs/latest/admin/config-cheat-sheet/

APP_NAME = Forge Metal
RUN_MODE = prod
RUN_USER = forgejo
WORK_PATH = /var/lib/forgejo

[server]
DOMAIN = {{ forgejo_domain }}
ROOT_URL = https://{{ forgejo_domain }}/
HTTP_PORT = {{ services.forgejo.port }}
HTTP_ADDR = {{ services.forgejo.host }}
SSH_DOMAIN = {{ forgejo_domain }}
SSH_PORT = {{ services.forgejo.ssh_port }}
SSH_LISTEN_PORT = {{ services.forgejo.ssh_port }}
START_SSH_SERVER = true
LFS_START_SERVER = true
OFFLINE_MODE = true

[database]
DB_TYPE = sqlite3
PATH = /var/lib/forgejo/data/forgejo.db

[repository]
ROOT = /var/lib/forgejo/repositories
DEFAULT_BRANCH = main

[lfs]
PATH = /var/lib/forgejo/data/lfs

[log]
MODE = console
LEVEL = info
ROOT_PATH = /var/lib/forgejo/log

[security]
INSTALL_LOCK = true

[service]
; DISABLE_REGISTRATION must be false for OIDC auto-account-creation to work.
; When true, it blocks ALL registration including from external auth sources.
; ALLOW_ONLY_EXTERNAL_REGISTRATION = true hides the manual signup form while
; still allowing Zitadel OIDC to auto-create accounts on first login.
DISABLE_REGISTRATION = false
ALLOW_ONLY_EXTERNAL_REGISTRATION = true
REQUIRE_SIGNIN_VIEW = false
; Disable both HTTP basic auth and Forgejo's built-in password sign-in UI.
ENABLE_BASIC_AUTHENTICATION = false
ENABLE_INTERNAL_SIGNIN = false

[oauth2]
ENABLED = true

[openid]
ENABLE_OPENID_SIGNIN = false
ENABLE_OPENID_SIGNUP = false

[actions]
ENABLED = true
DEFAULT_ACTIONS_URL = github
