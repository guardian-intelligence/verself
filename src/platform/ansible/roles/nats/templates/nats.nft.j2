# NATS is loopback-only. Clients authenticate with SPIFFE x509-SVIDs and NATS
# maps URI SANs to per-service authorization users.
table inet verself_nats
delete table inet verself_nats
table inet verself_nats {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.nats.endpoints.client.port }} iifname != "lo" drop
        tcp dport {{ topology_endpoints.nats.endpoints.monitoring.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != nats accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
