NODE_ENV=production
PORT={{ services.platform.port }}
HOST=127.0.0.1
VERSELF_DOMAIN={{ verself_domain }}
PRODUCT_BASE_URL=https://{{ platform_domain }}
BASE_URL=https://{{ platform_domain }}
SITE_ORIGIN=https://{{ platform_domain }}
OTEL_SERVICE_NAME=platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ services.otelcol.host }}:{{ services.otelcol.http_port }}

# Deploy correlation. Sourced from `scripts/deploy_identity.sh` when the playbook
# runs via `scripts/ansible-with-tunnel.sh`; falls back to empty when ansible-playbook
# is invoked directly. Both server-side initOtel() and the SSR-injected
# `<meta name="verself:deploy-*">` tags read these so every span (Node + browser)
# joins the deploy on `verself.deploy_run_key` in default.otel_traces.
VERSELF_DEPLOY_RUN_KEY={{ lookup('env', 'VERSELF_DEPLOY_RUN_KEY') | default('', true) }}
VERSELF_DEPLOY_ID={{ lookup('env', 'VERSELF_DEPLOY_ID') | default('', true) }}
VERSELF_COMMIT_SHA={{ lookup('env', 'VERSELF_COMMIT_SHA') | default('', true) }}
VERSELF_DEPLOY_PROFILE={{ deploy_profile | default('', true) }}
OTEL_RESOURCE_ATTRIBUTES=verself.deploy_run_key={{ lookup('env', 'VERSELF_DEPLOY_RUN_KEY') | default('', true) | urlencode }},verself.deploy_id={{ lookup('env', 'VERSELF_DEPLOY_ID') | default('', true) | urlencode }},verself.commit_sha={{ lookup('env', 'VERSELF_COMMIT_SHA') | default('', true) | urlencode }},verself.deploy_profile={{ deploy_profile | default('', true) | urlencode }}
