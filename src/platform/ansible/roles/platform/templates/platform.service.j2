[Unit]
Description=Verself Platform Docs Frontend (TanStack Start)
After=verself-firewall.target network.target
Requires=verself-firewall.target

[Service]
Type=simple
User={{ platform_runtime_user }}
Group={{ platform_runtime_group }}
WorkingDirectory={{ platform_app_dir }}
EnvironmentFile=/etc/platform/env
ExecStart={{ verself_bin }}/node --import ./instrumentation.mts .output/server/index.mjs
Restart=on-failure
RestartSec=5
Environment=PATH={{ verself_bin }}:/usr/bin:/bin
Environment=HOME={{ platform_state_dir }}
CapabilityBoundingSet=
ProtectHome=true
ProtectSystem=strict
ReadWritePaths={{ platform_state_dir }}
PrivateDevices=true
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
LockPersonality=true
NoNewPrivileges=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictRealtime=true
RestrictSUIDSGID=true
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
