# Cloudflare's published edge ranges (https://www.cloudflare.com/ips-v4 +
# https://www.cloudflare.com/ips-v6). Used by the global servers block below
# to mark Cloudflare as a trusted proxy so {remote_host} resolves to the real
# client IP (read from CF-Connecting-IP) instead of the Cloudflare edge IP.
# Without this, every X-Real-IP we set on backends and every {remote_host}
# placeholder would be a Cloudflare IP, breaking audit attribution and any
# IP-based allowlists we add later. The list updates infrequently; refresh by
# diffing against Cloudflare's published feeds.
{
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		client_ip_headers CF-Connecting-IP
	}
}

(access_log) {
	log_append <user_agent {http.request.header.User-Agent}
	log {
		output file /var/log/caddy/access.log {
			mode 0640
			roll_size 100MiB
			roll_keep 3
		}
		format filter {
			request>headers delete
			resp_headers delete
			request>uri regexp "\\?.*$" ""
			wrap json
		}
	}
}

# Caddy speaks h2c (HTTP/2 over cleartext, prior knowledge — no Upgrade dance)
# to every reverse_proxy that points at one of our Go services. h2c is binary-
# framed end-to-end so the public hop matches HTTP/2 framing strictness from
# the client edge through to the service. src/httpserver wraps every public-
# plane handler with h2c.NewHandler; the two must move together. Foreign
# upstreams (Forgejo, Grafana, Stalwart, Electric, verself-web, company,
# Zitadel — Zitadel sets its own h2c transport) stay HTTP/1.1.
(h2c_upstream) {
	transport http {
		versions h2c
	}
}

https://{{ topology_artifacts.nomad.origin.hostname }}:{{ topology_artifacts.nomad.origin.port }} {
	bind {{ topology_artifacts.nomad.origin.listen_host }}
	import access_log
	tls /etc/verself/pki/nomad-artifacts-server.pem /etc/verself/pki/private/nomad-artifacts-server-key.pem
	reverse_proxy{% for garage_node in topology_clusters.garage.nodes %} http://{{ topology_clusters.garage.host }}:{{ garage_node.s3_port }}{% endfor %}{{ "\n" }}
}

(api_security_headers) {
	header {
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
		Cross-Origin-Resource-Policy same-origin
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

# connect-src 'self' is load-bearing: it blocks the browser from calling any
# Go service origin directly (billing.api.<domain>, auth.<domain>, etc.), which
# enforces the architectural rule that browser code never holds Zitadel bearer
# tokens — all API traffic must traverse TanStack Start server functions on the
# same origin, which read the server-owned session and attach bearers there.
# See src/platform/docs/identity-and-iam.md (Frontend Sessions).
# script-src keeps 'unsafe-inline' because Vinxi/TanStack Start injects inline
# hydration scripts; tightening to nonces is a future hardening step.
(frontend_security_headers) {
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'; object-src 'none'"
		Cross-Origin-Opener-Policy same-origin
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

