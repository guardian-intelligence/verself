{
	order coraza_waf first
}

(waf) {
	coraza_waf {
		load_owasp_crs
		directives `
			Include @coraza.conf-recommended
			Include @crs-setup.conf.example
			Include @owasp_crs/*.conf
			SecRuleEngine {{ caddy_waf_mode }}
			SecResponseBodyAccess Off
		`
	}
}

(access_log) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
		format json
	}
}

{{ hyperdx_domain }} {
	import access_log
	import waf
	reverse_proxy {{ services.hyperdx.host }}:{{ services.hyperdx.app_port }}
}

{{ forgejo_domain }} {
	import access_log
	import waf
	reverse_proxy {{ services.forgejo.host }}:{{ services.forgejo.port }}
}

{{ billing_service_domain }} {
	import access_log
	import waf

	@stripe_webhook {
		method POST
		path /webhooks/stripe
	}
	handle @stripe_webhook {
		request_body {
			max_size 65536
		}
		reverse_proxy {{ services.billing.host }}:{{ services.billing.port }}
	}
	handle /webhooks/stripe {
		respond 405
	}

	# Default deny — no other paths exposed publicly.
	respond 404
}

{{ zitadel_domain }} {
	import access_log
	import waf
	reverse_proxy {{ services.zitadel.host }}:{{ services.zitadel.port }} {
		transport http {
			versions h2c
		}
	}
}
