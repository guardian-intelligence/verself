{
	order coraza_waf first
}

(waf_detection) {
	coraza_waf {
		load_owasp_crs
		directives `
			Include @coraza.conf-recommended
			Include @crs-setup.conf.example
			Include @owasp_crs/*.conf
			SecRuleEngine DetectionOnly
			SecResponseBodyAccess Off
		`
	}
}

(waf_blocking) {
	coraza_waf {
		load_owasp_crs
		directives `
			Include @coraza.conf-recommended
			Include @crs-setup.conf.example
			Include @owasp_crs/*.conf
			SecRuleEngine On
			SecResponseBodyAccess Off
		`
	}
}

(access_log) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 3
		}
		format json
	}
}

(api_security_headers) {
	header {
		Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
		Cross-Origin-Resource-Policy same-origin
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

# connect-src 'self' is load-bearing: it blocks the browser from calling any
# Go service origin directly (billing.<domain>, auth.<domain>, etc.), which
# enforces the architectural rule that browser code never holds Zitadel bearer
# tokens — all API traffic must traverse TanStack Start server functions on the
# same origin, which read the server-owned session and attach bearers there.
# See src/platform/docs/identity-and-iam.md (Frontend Sessions).
# script-src keeps 'unsafe-inline' because Vinxi/TanStack Start injects inline
# hydration scripts; tightening to nonces is a future hardening step.
(frontend_security_headers) {
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'; object-src 'none'"
		Cross-Origin-Opener-Policy same-origin
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

(sandbox_api_cors_headers) {
	header {
		Access-Control-Allow-Origin "https://{{ rent_a_sandbox_domain }}"
		Vary Origin
	}
}

(sandbox_rental_api_proxy) {
	import waf_blocking
	import sandbox_api_cors_headers
	import api_security_headers
	reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
		header_up X-Real-IP {remote_host}
	}
}

{{ grafana_domain }} {
	import access_log
	import waf_detection
	reverse_proxy {{ services.grafana.host }}:{{ services.grafana.port }}
}

{{ forgejo_domain }} {
	import access_log
	import waf_detection
	reverse_proxy {{ services.forgejo.host }}:{{ services.forgejo.port }}
}

http://{{ caddy_firecracker_host_service_ip }}:{{ services.firecracker_host_service.http_port }} {
	import access_log
	bind {{ caddy_firecracker_host_service_ip }}

	@forgejo_git_clone {
		method GET POST
		path_regexp forgejo_git ^/.+(\.git)?/(info/refs|git-upload-pack)$
	}
	handle @forgejo_git_clone {
		reverse_proxy {{ services.forgejo.host }}:{{ services.forgejo.port }} {
			header_up Host {{ forgejo_domain }}
			header_up X-Forwarded-Host {{ forgejo_domain }}
			header_up X-Forwarded-Proto https
		}
	}
	respond 403
}

{{ billing_service_domain }} {
	import access_log
	import waf_blocking

	@stripe_webhook {
		method POST
		path /webhooks/stripe
		client_ip {{ caddy_stripe_webhook_ips | join(' ') }}
	}
	@stripe_webhook_post {
		method POST
		path /webhooks/stripe
	}
	handle @stripe_webhook {
		request_body {
			max_size 65536
		}
		reverse_proxy {{ services.billing.host }}:{{ services.billing.port }}
	}
	handle @stripe_webhook_post {
		respond 403
	}
	handle /webhooks/stripe {
		respond 405
	}

	# Default deny — no other paths exposed publicly.
	respond 404
}

{{ rent_a_sandbox_domain }} {
	import access_log

	@sandbox_rental_github_actions_webhook {
		method POST
		path /webhooks/github/actions
	}
	handle @sandbox_rental_github_actions_webhook {
		import waf_detection
		request_body {
			max_size 1048576
		}
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /webhooks/github/actions {
		respond 405
	}

	@sandbox_rental_github_installation_callback {
		method GET
		path /github/installations/callback
	}
	handle @sandbox_rental_github_installation_callback {
		import waf_detection
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /github/installations/callback {
		respond 405
	}

	@api_preflight {
		method OPTIONS
		path /api/*
		header Origin *
	}
	handle @api_preflight {
		import waf_blocking
		import sandbox_api_cors_headers
		import api_security_headers
		header {
			Access-Control-Allow-Headers "Authorization, Content-Type, Idempotency-Key, X-Forge-Metal-Correlation-Id, X-Forge-Metal-Verification-Run"
			Access-Control-Allow-Methods "GET, POST, DELETE, OPTIONS"
			Access-Control-Max-Age 600
		}
		respond 204
	}

	@sandbox_api_small_json_mutation {
		method POST
		path /api/v1/billing/checkout /api/v1/billing/contracts
	}
	handle @sandbox_api_small_json_mutation {
		request_body {
			max_size 8192
		}
		import sandbox_rental_api_proxy
	}

	@sandbox_api_execution_submit {
		method POST
		path /api/v1/executions
	}
	handle @sandbox_api_execution_submit {
		request_body {
			max_size 65536
		}
		# This route intentionally accepts shell commands; CRS RCE blocking would
		# reject legitimate CI and sandbox workloads. Keep detection telemetry on.
		import waf_detection
		import sandbox_api_cors_headers
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}

	handle /api/* {
		request_body {
			max_size 1048576
		}
		import sandbox_rental_api_proxy
	}

	handle /v1/shape {
		import waf_detection
		uri query -secret
		uri query +secret {{ caddy_electric_api_secret }}
		reverse_proxy {{ services.electric.host }}:{{ services.electric.port }}
	}

	handle {
		import waf_detection
		import frontend_security_headers
		reverse_proxy {{ services.rent_a_sandbox.host }}:{{ services.rent_a_sandbox.port }}
	}
}

{{ stalwart_domain }} {
	import access_log
	import waf_detection

	handle /api/* {
		reverse_proxy {{ services.mailbox_service.host }}:{{ services.mailbox_service.port }}
	}

	handle /v1/shape {
		uri query -secret
		uri query +secret {{ caddy_electric_mail_api_secret }}
		reverse_proxy {{ services.electric_mail.host }}:{{ services.electric_mail.port }}
	}

	handle /jmap/session {
		reverse_proxy {{ services.mailbox_service.host }}:{{ services.mailbox_service.port }}
	}

	# JMAP discovery + protocol endpoints served by Stalwart directly.
	# /.well-known/jmap is RFC 8620 service discovery; /jmap is the
	# protocol endpoint used by JMAP clients after discovery.
	handle /.well-known/jmap {
		reverse_proxy {{ services.stalwart.host }}:{{ services.stalwart.http_port }}
	}
	handle /jmap/* {
		reverse_proxy {{ services.stalwart.host }}:{{ services.stalwart.http_port }}
	}
	handle /auth/* {
		reverse_proxy {{ services.stalwart.host }}:{{ services.stalwart.http_port }}
	}

	handle {
		import frontend_security_headers
		reverse_proxy {{ services.webmail.host }}:{{ services.webmail.port }}
	}
}

{{ letters_domain }} {
	import access_log
	import waf_detection

	handle {
		import frontend_security_headers
		reverse_proxy {{ services.letters.host }}:{{ services.letters.port }}
	}
}

{{ zitadel_domain }} {
	import access_log
	import waf_detection

	@identity_zitadel_action_api_credentials {
		method POST
		path /internal/zitadel/actions/api-credential-claims
	}
	handle @identity_zitadel_action_api_credentials {
		request_body {
			max_size 65536
		}
		import api_security_headers
		reverse_proxy {{ services.identity_service.host }}:{{ services.identity_service.port }}
	}
	handle /internal/zitadel/actions/api-credential-claims {
		respond 405
	}

	handle {
		reverse_proxy {{ services.zitadel.host }}:{{ services.zitadel.port }} {
			transport http {
				versions h2c
			}
		}
	}
}
