{{ verself_domain }} {
	import access_log

	# Public discovery surface for operator-device + workload-VM
	# onboarding. Files under /var/www/verself/.well-known/ are dropped
	# by the ssh_ca, openbao, and wireguard roles. Cache-Control gives
	# operator devices a 5-min reuse window without preventing CA
	# rotation from propagating quickly.
	@verself_well_known {
		method GET
		path /.well-known/verself-*
	}
	handle @verself_well_known {
		root * /var/www/verself
		header Cache-Control "public, max-age=300"
		header X-Content-Type-Options nosniff
		# `hide .*` is omitted on purpose: the served directory IS
		# `/var/www/verself/.well-known/`. file_server's hide patterns
		# are matched against the file's full on-disk path, so hiding
		# `.*` would suppress every file under the directory.
		file_server browse=false
	}

	handle /v1/shape {
		uri query -secret
		uri query +secret {{ caddy_electric_api_secret }}
		reverse_proxy {{ topology_endpoints.electric.endpoints.http.address }}
	}

	handle_path /notifications/* {
		uri query -secret
		uri query +secret {{ caddy_electric_notifications_api_secret }}
		reverse_proxy {{ topology_endpoints.electric_notifications.endpoints.http.address }}
	}

	@identity_browser_auth {
		path /api/v1/auth/login /api/v1/auth/callback /api/v1/auth/session /api/v1/auth/organization /api/v1/auth/logout
	}
	handle @identity_browser_auth {
		request_body {
			max_size 65536
		}
		import api_security_headers
		reverse_proxy {{ topology_endpoints.identity_service.endpoints.public_http.address }} {
			import h2c_upstream
		}
	}

	handle {
		import frontend_security_headers
		reverse_proxy {{ topology_endpoints.verself_web.endpoints.http.address }}
	}
}

{{ stalwart_domain }} {
	import access_log

	handle /jmap/session {
		reverse_proxy {{ topology_endpoints.mailbox_service.endpoints.public_http.address }} {
			import h2c_upstream
		}
	}

	# JMAP discovery + protocol endpoints served by Stalwart directly.
	# /.well-known/jmap is RFC 8620 service discovery; /jmap is the
	# protocol endpoint used by JMAP clients after discovery.
	handle /.well-known/jmap {
		reverse_proxy {{ topology_endpoints.stalwart.endpoints.http.address }}
	}
	handle /jmap/* {
		reverse_proxy {{ topology_endpoints.stalwart.endpoints.http.address }}
	}
	handle /auth/* {
		reverse_proxy {{ topology_endpoints.stalwart.endpoints.http.address }}
	}

	# Webmail frontend is retired. `mail.<domain>` remains the JMAP/protocol
	# origin; mailbox-service HTTP APIs live on mail.api.<domain>.
}

