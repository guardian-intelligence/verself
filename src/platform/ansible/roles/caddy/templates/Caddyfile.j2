http://{{ caddy_firecracker_host_service_ip }}:{{ services.firecracker_host_service.http_port }} {
	import access_log
	bind {{ caddy_firecracker_host_service_ip }}

	@forgejo_git_clone {
		method GET POST
		path_regexp forgejo_git ^/.+(\.git)?/(info/refs|git-upload-pack)$
	}
	handle @forgejo_git_clone {
		reverse_proxy {{ services.forgejo.host }}:{{ services.forgejo.port }} {
			header_up Host {{ forgejo_domain }}
			header_up X-Forwarded-Host {{ forgejo_domain }}
			header_up X-Forwarded-Proto https
		}
	}

	@github_runner_jit_config {
		method GET
		path /internal/sandbox/v1/github-runner-jit
	}
	handle @github_runner_jit_config {
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }}
	}
	@github_sticky_disk {
		path /internal/sandbox/v1/stickydisk/*
	}
	handle @github_sticky_disk {
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }}
	}
	@github_checkout {
		method POST
		path /internal/sandbox/v1/github-checkout/bundle
	}
	handle @github_checkout {
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }}
	}
	respond 403
}

{{ billing_service_domain }} {
	import access_log
	import waf_blocking
	import api_security_headers

	@stripe_webhook {
		method POST
		path /webhooks/stripe
		client_ip {{ caddy_stripe_webhook_ips | join(' ') }}
	}
	@stripe_webhook_post {
		method POST
		path /webhooks/stripe
	}
	handle @stripe_webhook {
		request_body {
			max_size 65536
		}
		reverse_proxy {{ services.billing.host }}:{{ services.billing.port }}
	}
	handle @stripe_webhook_post {
		respond 403
	}
	handle /webhooks/stripe {
		respond 405
	}

	handle /api/* {
		request_body {
			max_size 1048576
		}
		reverse_proxy {{ services.billing.host }}:{{ services.billing.port }} {
			header_up X-Real-IP {remote_host}
		}
	}

	respond 404
}

{{ sandbox_rental_service_domain }} {
	import access_log

	@sandbox_rental_github_actions_webhook {
		method POST
		path /webhooks/github/actions
	}
	handle @sandbox_rental_github_actions_webhook {
		import waf_detection
		request_body {
			max_size 1048576
		}
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /webhooks/github/actions {
		respond 405
	}

	@sandbox_rental_github_installation_callback {
		method GET
		path /github/installations/callback
	}
	handle @sandbox_rental_github_installation_callback {
		import waf_detection
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /github/installations/callback {
		respond 405
	}

	@sandbox_api_small_json_mutation {
		method POST
		path /api/v1/billing/checkout /api/v1/billing/contracts
	}
	handle @sandbox_api_small_json_mutation {
		request_body {
			max_size 8192
		}
		import sandbox_rental_api_proxy
	}

	@sandbox_api_execution_submit {
		method POST
		path /api/v1/executions
	}
	handle @sandbox_api_execution_submit {
		request_body {
			max_size 65536
		}
		# This route intentionally accepts shell commands; CRS RCE blocking would
		# reject legitimate CI and sandbox workloads. Keep detection telemetry on.
		import waf_detection
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}

	@sandbox_api_execution_schedule_create {
		method POST
		path /api/v1/execution-schedules
	}
	handle @sandbox_api_execution_schedule_create {
		request_body {
			max_size 65536
		}
		# Schedule creation persists the same run_command payload used by direct
		# executions; keep CRS telemetry, but do not block valid sandbox jobs.
		import waf_detection
		import api_security_headers
		reverse_proxy {{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }} {
			header_up X-Real-IP {remote_host}
		}
	}

	handle /api/* {
		request_body {
			max_size 1048576
		}
		import sandbox_rental_api_proxy
	}

	respond 404
}

