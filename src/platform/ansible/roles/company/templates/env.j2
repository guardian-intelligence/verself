NODE_ENV=production
PORT={{ services.company.port }}
HOST=127.0.0.1
FORGE_METAL_DOMAIN={{ forge_metal_domain }}
SITE_ORIGIN=https://{{ company_domain }}
BASE_URL=https://{{ company_domain }}
OTEL_SERVICE_NAME=company
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ services.otelcol.host }}:{{ services.otelcol.http_port }}

# Deploy correlation — identical to platform. Both server-side initOtel() and
# the SSR-injected `<meta name="forge-metal:deploy-*">` tags read these so
# every span (Node + browser) joins the deploy on `forge_metal.deploy_run_key`.
FORGE_METAL_DEPLOY_RUN_KEY={{ lookup('env', 'FORGE_METAL_DEPLOY_RUN_KEY') | default('', true) }}
FORGE_METAL_DEPLOY_ID={{ lookup('env', 'FORGE_METAL_DEPLOY_ID') | default('', true) }}
FORGE_METAL_COMMIT_SHA={{ lookup('env', 'FORGE_METAL_COMMIT_SHA') | default('', true) }}
FORGE_METAL_DEPLOY_PROFILE={{ deploy_profile | default('', true) }}
OTEL_RESOURCE_ATTRIBUTES=forge_metal.deploy_run_key={{ lookup('env', 'FORGE_METAL_DEPLOY_RUN_KEY') | default('', true) | urlencode }},forge_metal.deploy_id={{ lookup('env', 'FORGE_METAL_DEPLOY_ID') | default('', true) | urlencode }},forge_metal.commit_sha={{ lookup('env', 'FORGE_METAL_COMMIT_SHA') | default('', true) | urlencode }},forge_metal.deploy_profile={{ deploy_profile | default('', true) | urlencode }}
