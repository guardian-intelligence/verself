NODE_ENV=production
PORT={{ topology_endpoints.company.endpoints.http.port }}
HOST=127.0.0.1
VERSELF_DOMAIN={{ verself_domain }}
COMPANY_DOMAIN={{ company_domain }}
PRODUCT_BASE_URL=https://{{ verself_domain }}
SITE_ORIGIN=https://{{ company_domain }}
BASE_URL=https://{{ company_domain }}
OTEL_SERVICE_NAME=company
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ topology_endpoints.otelcol.endpoints.otlp_http.address }}

# Deploy correlation — identical to platform. Both server-side initOtel() and
# the SSR-injected `<meta name="verself:deploy-*">` tags read these so
# every span (Node + browser) joins the deploy on `verself.deploy_run_key`.
VERSELF_DEPLOY_RUN_KEY={{ lookup('env', 'VERSELF_DEPLOY_RUN_KEY') | default('', true) }}
VERSELF_DEPLOY_ID={{ lookup('env', 'VERSELF_DEPLOY_ID') | default('', true) }}
VERSELF_COMMIT_SHA={{ lookup('env', 'VERSELF_COMMIT_SHA') | default('', true) }}
VERSELF_DEPLOY_PROFILE={{ deploy_profile | default('', true) }}
OTEL_RESOURCE_ATTRIBUTES=verself.deploy_run_key={{ lookup('env', 'VERSELF_DEPLOY_RUN_KEY') | default('', true) | urlencode }},verself.deploy_id={{ lookup('env', 'VERSELF_DEPLOY_ID') | default('', true) | urlencode }},verself.commit_sha={{ lookup('env', 'VERSELF_COMMIT_SHA') | default('', true) | urlencode }},verself.deploy_profile={{ deploy_profile | default('', true) | urlencode }}
