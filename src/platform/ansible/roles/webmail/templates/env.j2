NODE_ENV=production
PORT={{ services.webmail.port }}
HOST=127.0.0.1
FORGE_METAL_DOMAIN={{ forge_metal_domain }}
AUTH_SUBDOMAIN=auth
OTEL_SERVICE_NAME=webmail
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ services.otelcol.host }}:{{ services.otelcol.http_port }}
AUTH_CLIENT_ID={{ webmail_client_id }}
