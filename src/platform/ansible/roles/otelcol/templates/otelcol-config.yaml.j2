receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:{{ services.otelcol.grpc_port }}
      http:
        endpoint: 127.0.0.1:{{ services.otelcol.http_port }}
  filelog/caddy:
    include: [/var/log/caddy/access.log]
    storage: file_storage
    resource:
      service.name: caddy
    operators:
      - type: json_parser
        timestamp:
          parse_from: attributes.ts
          layout_type: epoch
          layout: s.ns
      - type: move
        from: attributes.request.remote_ip
        to: attributes.client_ip
      - type: move
        from: attributes.request.method
        to: attributes.http_method
      - type: move
        from: attributes.request.host
        to: attributes.http_host
      - type: move
        from: attributes.request.uri
        to: attributes.http_uri
      - type: move
        from: attributes.request.proto
        to: attributes.http_proto
      - type: move
        from: attributes.status
        to: attributes.http_status
      - type: move
        from: attributes.size
        to: attributes.resp_size_bytes
      - type: move
        from: attributes.duration
        to: attributes.duration_s
      - type: move
        from: attributes.request.headers.User-Agent
        to: attributes.user_agent
      - type: remove
        field: attributes.request
      - type: remove
        field: attributes.resp_headers
      # Severity from HTTP status code (range-based)
      - type: router
        routes:
          - expr: 'attributes.http_status >= 500'
            output: set_severity_error
          - expr: 'attributes.http_status >= 400'
            output: set_severity_warn
        default: set_severity_info
      - id: set_severity_error
        type: add
        field: attributes._severity
        value: ERROR
        output: parse_severity
      - id: set_severity_warn
        type: add
        field: attributes._severity
        value: WARN
        output: parse_severity
      - id: set_severity_info
        type: add
        field: attributes._severity
        value: INFO
        output: parse_severity
      - id: parse_severity
        type: severity_parser
        parse_from: attributes._severity
      - type: remove
        field: attributes._severity
  journald/caddy:
    units: [caddy]
    resource:
      service.name: caddy
  journald/zitadel:
    units: [zitadel]
    resource:
      service.name: zitadel
    operators:
      # The journald receiver emits body as map[string]interface{} (Go map,
      # not a JSON string). Extract the MESSAGE field to body first, then
      # parse the Zitadel JSON log (slog.JSONHandler output).
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.TraceID
        span_id:
          parse_from: attributes.SpanID
        if: attributes.TraceID != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      # Flatten nested request object
      - type: move
        from: attributes.request.id
        to: attributes.request_id
        if: attributes.request != nil
      - type: move
        from: attributes.request.instance_host
        to: attributes.instance_host
        if: attributes.request != nil
      # Rename to avoid collision with OTel resource service.name
      - type: move
        from: attributes.service
        to: attributes.zitadel_service
        if: attributes.service != nil
      # Clean up parsed intermediate fields
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.TraceID
        if: attributes.TraceID != nil
      - type: remove
        field: attributes.SpanID
        if: attributes.SpanID != nil
      - type: remove
        field: attributes.request
        if: attributes.request != nil
      - type: remove
        field: attributes.source
        if: attributes.source != nil
  # App logs for billing-service and sandbox-rental flow through OTLP (via
  # otelslog bridge), not journald. These receivers capture only systemd
  # lifecycle messages (start/stop/crash) and pre-init fatal errors.
  journald/billing-service:
    units: [billing-service]
    resource:
      service.name: billing-service
  journald/sandbox-rental:
    units: [sandbox-rental-service]
    resource:
      service.name: sandbox-rental-service
  journald/rent-a-sandbox:
    units: [rent-a-sandbox]
    resource:
      service.name: rent-a-sandbox
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.trace_id
        span_id:
          parse_from: attributes.span_id
        if: attributes.trace_id != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.trace_id
        if: attributes.trace_id != nil
      - type: remove
        field: attributes.span_id
        if: attributes.span_id != nil
  journald/webmail:
    units: [webmail]
    resource:
      service.name: webmail
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.trace_id
        span_id:
          parse_from: attributes.span_id
        if: attributes.trace_id != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.trace_id
        if: attributes.trace_id != nil
      - type: remove
        field: attributes.span_id
        if: attributes.span_id != nil
  journald/letters:
    units: [letters]
    resource:
      service.name: letters
    operators:
      - type: move
        from: body.MESSAGE
        to: body
      - type: json_parser
        parse_from: body
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: "2006-01-02T15:04:05.999999999Z07:00"
      - type: trace_parser
        trace_id:
          parse_from: attributes.trace_id
        span_id:
          parse_from: attributes.span_id
        if: attributes.trace_id != nil
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          info: INFO
          warn: WARN
          error: ERROR
          debug: DEBUG
      - type: move
        from: attributes.msg
        to: body
      - type: remove
        field: attributes.time
        if: attributes.time != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
      - type: remove
        field: attributes.trace_id
        if: attributes.trace_id != nil
      - type: remove
        field: attributes.span_id
        if: attributes.span_id != nil
  journald/vm-orchestrator:
    units: [vm-orchestrator]
    resource:
      service.name: vm-orchestrator
  postgresql:
    endpoint: "{{ services.postgresql.host }}:{{ services.postgresql.port }}"
    username: postgres
    password: "{{ postgresql_admin_password }}"
    databases: [sandbox_rental]
    collection_interval: 10s
    tls:
      insecure: true
  filelog/postgresql:
    include: [{{ postgresql_log_dir }}/postgresql-*.log]
    storage: file_storage
    resource:
      service.name: postgresql
    multiline:
      line_start_pattern: '^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}'
    operators:
      - type: regex_parser
        regex: '^(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d+ \w+) \[(?P<pid>\d+)\]\s*(?:(?P<user>\S+)@(?P<database>\S+)\s+)?(?P<level>\w+):\s+(?P<message>.*)'
        timestamp:
          parse_from: attributes.timestamp
          layout_type: gotime
          layout: "2006-01-02 15:04:05.000 MST"
      - type: severity_parser
        parse_from: attributes.level
        mapping:
          debug: [DEBUG, DEBUG1, DEBUG2, DEBUG3, DEBUG4, DEBUG5]
          info: [INFO, LOG, NOTICE]
          warn: WARNING
          error: [ERROR, FATAL, PANIC]
      - type: move
        from: attributes.message
        to: body
      - type: remove
        field: attributes.timestamp
        if: attributes.timestamp != nil
      - type: remove
        field: attributes.level
        if: attributes.level != nil
  hostmetrics:
    collection_interval: 1s
    scrapers:
      process:
        include:
          match_type: regexp
          names: ["billing-service", "sandbox-rental.*", "caddy", "clickhouse.*", "ClickHouse.*", "forgejo.*", "otelcol.*", "mongod", "node", "forge-metal", "verdaccio", "next-server.*", "npm", "vm-orchestrator.*", "tigerbeetle", "zitadel", "postgres"]
        mute_process_exe_error: true
        mute_process_io_error: true
      cpu: {}
      memory: {}
      load: {}
      filesystem:
        include_fs_types:
          match_type: strict
          fs_types: [ext4, zfs]
      disk: {}
      network: {}
  statsd:
    endpoint: "{{ services.tigerbeetle.host }}:{{ services.tigerbeetle.statsd_port }}"
    aggregation_interval: 10s

processors:
  batch:
    send_batch_size: 10000
    timeout: 5s

exporters:
  clickhouse:
    endpoint: tcp://{{ services.clickhouse.host }}:{{ services.clickhouse.native_port }}?dial_timeout=10s&username=default&password={{ clickhouse_password | urlencode }}
    database: default
    logs_table_name: otel_logs
    traces_table_name: otel_traces
    create_schema: false

extensions:
  health_check:
    endpoint: 127.0.0.1:13133  # not in service registry — no cross-service consumers
  file_storage:
    directory: /var/lib/otelcol/storage

service:
  extensions: [health_check, file_storage]
  pipelines:
    logs:
      receivers: [otlp, filelog/caddy, journald/caddy, journald/billing-service, journald/sandbox-rental, journald/rent-a-sandbox, journald/webmail, journald/letters, journald/zitadel, journald/vm-orchestrator, filelog/postgresql]
      processors: [batch]
      exporters: [clickhouse]
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [clickhouse]
    metrics:
      receivers: [otlp, hostmetrics, postgresql, statsd]
      processors: [batch]
      exporters: [clickhouse]
