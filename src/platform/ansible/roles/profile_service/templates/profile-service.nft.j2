#!/usr/sbin/nft -f
# Profile service is loopback-only. It needs PostgreSQL, identity-service
# internal mTLS for name writes, governance-service internal audit, Zitadel OIDC discovery,
# and OTLP egress.

table inet verself_profile_service
delete table inet verself_profile_service

table inet verself_profile_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.profile_service.endpoints.public_http.port }} iifname != "lo" drop
        tcp dport {{ topology_endpoints.profile_service.endpoints.internal_https.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != profile_service accept

        oifname "lo" tcp dport {{ topology_endpoints.postgresql.endpoints.postgres.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.identity_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.governance_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.zitadel.endpoints.http.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
