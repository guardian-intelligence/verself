#!/usr/sbin/nft -f
# Identity service is a loopback-only API. It needs PostgreSQL, Zitadel admin APIs,
# governance's SPIFFE mTLS audit intake, ClickHouse ledger projection, and OTLP egress.

table inet verself_identity_service
delete table inet verself_identity_service

table inet verself_identity_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ services.identity_service.port }} iifname != "lo" drop
        tcp dport {{ services.identity_service.internal_port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != identity_service accept

        oifname "lo" tcp dport {{ services.postgresql.port }} accept
        oifname "lo" tcp dport {{ services.clickhouse.secure_native_port }} accept
        oifname "lo" tcp dport {{ services.zitadel.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ services.governance_service.internal_port }} accept
        oifname "lo" tcp dport {{ services.otelcol.grpc_port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
