#!/usr/sbin/nft -f
# Identity service is a loopback-only API. It needs PostgreSQL, Zitadel admin APIs,
# governance's SPIFFE mTLS audit intake, ClickHouse ledger projection, and OTLP egress.

table inet verself_identity_service
delete table inet verself_identity_service

table inet verself_identity_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.identity_service.endpoints.public_http.port }} iifname != "lo" drop
        tcp dport {{ topology_endpoints.identity_service.endpoints.internal_https.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != identity_service accept

        oifname "lo" tcp dport {{ topology_endpoints.postgresql.endpoints.postgres.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.clickhouse.endpoints.native_tls.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.zitadel.endpoints.http.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ topology_endpoints.governance_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
