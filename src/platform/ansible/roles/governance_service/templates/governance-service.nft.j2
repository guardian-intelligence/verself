#!/usr/sbin/nft -f
# Governance service is loopback-only and needs PostgreSQL, ClickHouse, OpenBao,
# Zitadel JWKS, and OTLP egress.

table inet forge_metal_governance_service
delete table inet forge_metal_governance_service

table inet forge_metal_governance_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ services.governance_service.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != governance_service accept

        oifname "lo" tcp dport {{ services.postgresql.port }} accept
        oifname "lo" tcp dport {{ services.clickhouse.secure_native_port }} accept
        oifname "lo" tcp dport {{ services.openbao.port }} accept
        oifname "lo" tcp dport {{ services.profile_service.internal_port }} accept
        oifname "lo" tcp dport {{ services.zitadel.port }} accept
        oifname "lo" tcp dport {{ services.otelcol.grpc_port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
