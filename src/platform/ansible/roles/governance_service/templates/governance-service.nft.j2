#!/usr/sbin/nft -f
# Governance service is loopback-only and needs PostgreSQL, ClickHouse, OpenBao,
# Zitadel OIDC discovery via local Caddy, and OTLP egress.

table inet verself_governance_service
delete table inet verself_governance_service

table inet verself_governance_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.governance_service.endpoints.public_http.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != governance_service accept

        oifname "lo" tcp dport {{ topology_endpoints.postgresql.endpoints.postgres.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.clickhouse.endpoints.native_tls.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.openbao.endpoints.api.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.profile_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.zitadel.endpoints.http.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
