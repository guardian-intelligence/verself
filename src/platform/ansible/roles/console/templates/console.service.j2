[Unit]
Description=Console Frontend (TanStack Start)
After=forge-metal-firewall.target network.target sandbox-rental-service.service identity-service.service notifications-service.service electric.service electric-notifications.service
Requires=forge-metal-firewall.target
Wants=sandbox-rental-service.service identity-service.service notifications-service.service electric.service electric-notifications.service

[Service]
Type=simple
User={{ console_runtime_user }}
Group={{ console_runtime_group }}
WorkingDirectory={{ console_app_dir }}
EnvironmentFile=/etc/console/env
ExecStart={{ fm_bin }}/node --import ./instrumentation.mts .output/server/index.mjs
Restart=on-failure
RestartSec=5
Environment=PATH={{ fm_bin }}:/usr/bin:/bin
Environment=HOME={{ console_state_dir }}
CapabilityBoundingSet=
ProtectHome=true
ProtectSystem=strict
ReadWritePaths={{ console_state_dir }}
PrivateDevices=true
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
LockPersonality=true
NoNewPrivileges=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictRealtime=true
RestrictSUIDSGID=true
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
