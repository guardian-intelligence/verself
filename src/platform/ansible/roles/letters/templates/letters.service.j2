[Unit]
Description=Letters Blog Frontend (TanStack Start)
After=forge-metal-firewall.target network.target
Requires=forge-metal-firewall.target

[Service]
Type=simple
User={{ letters_runtime_user }}
Group={{ letters_runtime_group }}
WorkingDirectory={{ letters_app_dir }}
EnvironmentFile=/etc/letters/env
ExecStart={{ fm_bin }}/node --import ./instrumentation.mts .output/server/index.mjs
Restart=on-failure
RestartSec=5
Environment=PATH={{ fm_bin }}:/usr/bin:/bin
Environment=HOME={{ letters_state_dir }}
CapabilityBoundingSet=
ProtectHome=true
ProtectSystem=strict
ReadWritePaths={{ letters_state_dir }}
PrivateDevices=true
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
LockPersonality=true
NoNewPrivileges=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictRealtime=true
RestrictSUIDSGID=true
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
