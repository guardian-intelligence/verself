#!/usr/sbin/nft -f
# Source-code-hosting-service is loopback-only. Public access must arrive via
# Caddy and internal archive downloads must arrive over SPIFFE mTLS.

table inet verself_source_code_hosting_service
delete table inet verself_source_code_hosting_service

table inet verself_source_code_hosting_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.source_code_hosting_service.endpoints.public_http.port }} iifname != "lo" drop
        tcp dport {{ topology_endpoints.source_code_hosting_service.endpoints.internal_https.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != source_code_hosting_service accept

        oifname "lo" tcp dport {{ topology_endpoints.postgresql.endpoints.postgres.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.forgejo.endpoints.http.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.sandbox_rental.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.secrets_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.projects_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.identity_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.zitadel.endpoints.http.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
