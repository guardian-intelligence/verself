path "{{ openbao_tenancy_kv_mount }}/data/opaque_credential/*" {
  capabilities = ["create", "read", "update"]
}

path "{{ openbao_tenancy_kv_mount }}/metadata/opaque_credential/*" {
  capabilities = ["read", "list"]
}

path "{{ openbao_tenancy_transit_mount }}/keys/verself-opaque-credential-hmac" {
  capabilities = ["create", "read", "update"]
}

path "{{ openbao_tenancy_transit_mount }}/hmac/verself-opaque-credential-hmac" {
  capabilities = ["update"]
}

path "{{ openbao_tenancy_transit_mount }}/hmac/verself-opaque-credential-hmac/sha2-256" {
  capabilities = ["update"]
}

path "{{ openbao_tenancy_transit_mount }}/verify/verself-opaque-credential-hmac" {
  capabilities = ["update"]
}

path "{{ openbao_tenancy_transit_mount }}/verify/verself-opaque-credential-hmac/sha2-256" {
  capabilities = ["update"]
}
