[Unit]
Description=Verdaccio npm registry mirror
After=verself-firewall.target network.target
Requires=verself-firewall.target

[Service]
Type=simple
ExecStart={{ verdaccio_install_prefix }}/bin/verdaccio --config /etc/verdaccio/config.yaml
Restart=on-failure
User=verdaccio
Group=verdaccio
WorkingDirectory=/var/lib/verdaccio
CPUAffinity=0 1
Environment=HOME=/var/lib/verdaccio
Environment=PATH={{ verdaccio_install_prefix }}/bin:{{ verself_bin }}:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
