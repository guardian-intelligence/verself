#!/usr/sbin/nft -f
# Secrets service is a loopback-only API. It needs PostgreSQL, Zitadel, governance audit, and OTLP egress.

table inet forge_metal_secrets_service
delete table inet forge_metal_secrets_service

table inet forge_metal_secrets_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ services.secrets_service.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != secrets_service accept

        oifname "lo" tcp dport {{ services.postgresql.port }} accept
        oifname "lo" tcp dport {{ services.zitadel.port }} accept
        oifname "lo" tcp dport {{ services.governance_service.port }} accept
        oifname "lo" tcp dport {{ services.otelcol.grpc_port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
