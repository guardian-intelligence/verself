#!/usr/sbin/nft -f
# Secrets service is a loopback-only API. It needs Zitadel, OpenBao, billing,
# governance audit, and OTLP egress. Billing and governance calls use their
# SPIFFE mTLS internal listeners, not the customer-facing loopback ports.

table inet verself_secrets_service
delete table inet verself_secrets_service

table inet verself_secrets_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ services.secrets_service.port }} iifname != "lo" drop
        tcp dport {{ services.secrets_service.internal_port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != secrets_service accept

        oifname "lo" tcp dport {{ services.zitadel.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ services.openbao.port }} accept
        oifname "lo" tcp dport {{ services.billing.internal_port }} accept
        oifname "lo" tcp dport {{ services.governance_service.internal_port }} accept
        oifname "lo" tcp dport {{ services.otelcol.grpc_port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
