#!/usr/sbin/nft -f
# Secrets service is a loopback-only API. It needs Zitadel, OpenBao, billing,
# governance audit, and OTLP egress. Billing and governance calls use their
# SPIFFE mTLS internal listeners, not the customer-facing loopback ports.

table inet verself_secrets_service
delete table inet verself_secrets_service

table inet verself_secrets_service {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport {{ topology_endpoints.secrets_service.endpoints.public_http.port }} iifname != "lo" drop
        tcp dport {{ topology_endpoints.secrets_service.endpoints.internal_https.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != secrets_service accept

        oifname "lo" tcp dport {{ topology_endpoints.zitadel.endpoints.http.port }} accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ topology_endpoints.openbao.endpoints.api.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.billing.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.governance_service.endpoints.internal_https.port }} accept
        oifname "lo" tcp dport {{ topology_endpoints.otelcol.endpoints.otlp_grpc.port }} accept
        meta l4proto != tcp meta l4proto != udp accept

        drop
    }
}
