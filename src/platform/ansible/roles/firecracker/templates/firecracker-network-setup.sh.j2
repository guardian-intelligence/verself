#!/usr/bin/env bash
set -euo pipefail

# Enable IP forwarding (also persisted via sysctl.d, this covers the first boot).
sysctl -w net.ipv4.ip_forward=1 >/dev/null

# Explicitly undo the old localhost-DNAT path; guests use verself-host0 instead.
sysctl -w net.ipv4.conf.all.route_localnet=0 >/dev/null
sysctl -w net.ipv4.conf.default.route_localnet=0 >/dev/null

# Host-only service plane for selected platform endpoints reachable from guests.
HOST_SERVICE_IF="{{ firecracker_host_service_interface }}"
HOST_SERVICE_CIDR="{{ firecracker_host_service_ip }}/32"

if ! ip link show "$HOST_SERVICE_IF" >/dev/null 2>&1; then
    ip link add "$HOST_SERVICE_IF" type dummy
fi
ip addr replace "$HOST_SERVICE_CIDR" dev "$HOST_SERVICE_IF"
ip link set "$HOST_SERVICE_IF" up

# --- Migrate: remove old iptables-nft compat rules ---
# Previous versions used iptables (translated to nft compat tables via
# iptables-nft). Clean up our chains only; the provider's metadata DNAT
# rule (169.254.169.254) lives in the compat nat table and is preserved.
UPLINK="{{ firecracker_resolved_uplink }}"
POOL="{{ firecracker_guest_pool_cidr }}"

# filter table: VERSELF_FC_FWD chain + jump rules
iptables -D FORWARD -s "$POOL" -j VERSELF_FC_FWD 2>/dev/null || true
iptables -D FORWARD -i "$UPLINK" -d "$POOL" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true
iptables -F VERSELF_FC_FWD 2>/dev/null || true
iptables -X VERSELF_FC_FWD 2>/dev/null || true

# nat table: VERSELF_FC_NAT chain + jump rule
iptables -t nat -D POSTROUTING -s "$POOL" -j VERSELF_FC_NAT 2>/dev/null || true
iptables -t nat -F VERSELF_FC_NAT 2>/dev/null || true
iptables -t nat -X VERSELF_FC_NAT 2>/dev/null || true

# Remove stale /30 masquerade rules (accumulated from earlier CIDR mismatch)
for _ in $(seq 1 10); do
    iptables -t nat -D POSTROUTING -s 172.16.0.0/30 -o "$UPLINK" -j MASQUERADE 2>/dev/null || break
done

# --- Load native nftables ruleset (atomic table replace) ---
nft -f /etc/nftables.d/firecracker.nft
