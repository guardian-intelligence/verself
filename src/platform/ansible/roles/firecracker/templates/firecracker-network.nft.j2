#!/usr/sbin/nft -f
# Firecracker guest networking: NAT + forwarding for {{ firecracker_guest_pool_cidr }}.
# Managed by Ansible — do not edit manually.

# Atomic replace: create (no-op if exists), delete, recreate.
table ip forge_metal_firecracker
delete table ip forge_metal_firecracker

table ip forge_metal_firecracker {
    chain forward {
        type filter hook forward priority filter; policy drop;

        # Block guest-to-guest lateral movement
        ip saddr {{ firecracker_guest_pool_cidr }} ip daddr {{ firecracker_guest_pool_cidr }} drop

        # Block outbound SMTP (MTA-to-MTA, port 25) from guests. Matches the
        # default posture of every major cloud: prevents compromised/abuse VMs
        # from sending direct-to-MX spam and torching our uplink IP reputation.
        # Submission ports 465/587 remain open so tenants can still relay
        # through SendGrid/Mailgun/etc. with authentication.
        #
        # Footgun: `limit` is a match, not a log modifier. Combining them on
        # one rule would fail the match past the rate cap and *allow* the
        # packet through. Keep the rate-limited log and the unconditional drop
        # as two separate rules.
        ip saddr {{ firecracker_guest_pool_cidr }} tcp dport 25 \
            limit rate 10/minute log prefix "fc-smtp-block: "
        ip saddr {{ firecracker_guest_pool_cidr }} tcp dport 25 counter drop

        # Guest outbound to internet via uplink
        ip saddr {{ firecracker_guest_pool_cidr }} oifname "{{ firecracker_resolved_uplink }}" accept

        # Return traffic from internet to guests (stateful)
        ip daddr {{ firecracker_guest_pool_cidr }} iifname "{{ firecracker_resolved_uplink }}" ct state established,related accept

        # Drop all other inbound to guest pool
        ip daddr {{ firecracker_guest_pool_cidr }} drop
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        ip saddr {{ firecracker_guest_pool_cidr }} oifname "{{ firecracker_resolved_uplink }}" masquerade
    }
}
