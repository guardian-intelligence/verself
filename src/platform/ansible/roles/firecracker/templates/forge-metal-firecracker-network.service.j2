[Unit]
Description=Configure forge-metal Firecracker host networking
After=forge-metal-firewall.target network-online.target
Requires=forge-metal-firewall.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/forge-metal-firecracker-network-setup
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
