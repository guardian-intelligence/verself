#!/usr/sbin/nft -f
# Sandbox rental service network restrictions.
# Binds 127.0.0.1:4243 (loopback-only). Caddy reverse-proxies to it.
#
# The service runs as User=sandbox_rental. Egress is restricted by skuid:
# loopback platform dependencies plus DNS/HTTPS to public git hosts only.

table inet forge_metal_sandbox_rental
delete table inet forge_metal_sandbox_rental

table inet forge_metal_sandbox_rental {
    chain input {
        type filter hook input priority filter; policy accept;

        # Reject external connections to the sandbox-rental port.
        # Only loopback (Caddy reverse proxy) is allowed.
        tcp dport {{ services.sandbox_rental.port }} iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        # Allow reply packets for accepted inbound connections to the local listener.
        ct state established,related accept

        # Allow all traffic from other users.
        meta skuid != sandbox_rental accept

        # Allow loopback traffic to local services.
        oifname "lo" tcp dport {{ services.postgresql.port }} accept
        oifname "lo" tcp dport {{ services.clickhouse.secure_native_port }} accept
        oifname "lo" tcp dport {{ services.billing.internal_port }} accept
        oifname "lo" tcp dport {{ services.openbao.port }} accept
        oifname "lo" tcp dport {{ services.zitadel.port }} accept
        oifname "lo" tcp dport {{ services.governance_service.internal_port }} accept
        oifname "lo" tcp dport {{ services.secrets_service.internal_port }} accept
        oifname "lo" tcp dport {{ services.forgejo.port }} accept
        oifname "lo" tcp dport {{ services.temporal.grpc_port }} accept
        oifname "lo" tcp dport {{ services.otelcol.grpc_port }} accept
        oifname "lo" tcp dport 53 accept
        oifname "lo" udp dport 53 accept

        # Keep public clone egress from becoming a private-network SSRF path.
        ip daddr { 0.0.0.0/8, 10.0.0.0/8, 100.64.0.0/10, 127.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.0.0.0/24, 192.0.2.0/24, 192.168.0.0/16, 198.18.0.0/15, 198.51.100.0/24, 203.0.113.0/24, 224.0.0.0/4, 240.0.0.0/4 } drop
        ip6 daddr { ::/128, ::1/128, ::ffff:0:0/96, 64:ff9b::/96, 100::/64, 2001::/23, 2001:db8::/32, fc00::/7, fe80::/10, ff00::/8 } drop

        # DNS resolution for cloning public git repos (GitHub, GitLab, etc.).
        tcp dport 53 accept
        udp dport 53 accept

        # HTTPS egress for cloning public git repos.
        tcp dport 443 accept

        # Allow Unix socket traffic (always passes output chain).
        meta l4proto != tcp meta l4proto != udp accept

        # Drop all other outbound traffic from sandbox_rental user.
        drop
    }
}
