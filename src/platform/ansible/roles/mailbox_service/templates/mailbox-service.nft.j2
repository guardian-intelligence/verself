#!/usr/sbin/nft -f
# Mailbox service egress restrictions.
# Loopback is required for Stalwart JMAP, PostgreSQL, and OIDC discovery through local Caddy.
# HTTPS and DNS are still required for operator forwarding through Resend.

table inet verself_mailbox_service
delete table inet verself_mailbox_service

table inet verself_mailbox_service {
    chain output {
        type filter hook output priority filter; policy accept;

        meta skuid != mailbox_service accept
        oifname "lo" accept
        ct state established,related accept
        tcp dport 443 accept
        tcp dport 53 accept
        udp dport 53 accept
        drop
    }
}
