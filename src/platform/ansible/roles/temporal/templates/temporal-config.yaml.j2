log:
  stdout: true
  level: info
  format: json

persistence:
  defaultStore: postgres-default
  visibilityStore: postgres-visibility
  numHistoryShards: {{ temporal_num_history_shards }}
  datastores:
    postgres-default:
      sql:
        pluginName: "{{ temporal_sql_plugin }}"
        databaseName: "{{ temporal_postgresql_database }}"
        connectAddr: "{{ temporal_postgresql_socket_dir }}"
        connectProtocol: unix
        user: "{{ temporal_postgresql_user }}"
        maxConns: 20
        maxIdleConns: 20
        maxConnLifetime: 1h
        connectAttributes:
          sslmode: disable
          application_name: temporal-server
          connect_timeout: "5"
    postgres-visibility:
      sql:
        pluginName: "{{ temporal_sql_plugin }}"
        databaseName: "{{ temporal_visibility_database }}"
        connectAddr: "{{ temporal_postgresql_socket_dir }}"
        connectProtocol: unix
        user: "{{ temporal_postgresql_user }}"
        maxConns: 10
        maxIdleConns: 10
        maxConnLifetime: 1h
        connectAttributes:
          sslmode: disable
          application_name: temporal-server
          connect_timeout: "5"

global:
  membership:
    maxJoinDuration: 30s
    broadcastAddress: "{{ topology_endpoints.temporal.host }}"
  pprof:
    port: {{ topology_endpoints.temporal.endpoints.pprof.port }}
  metrics:
    prometheus:
      framework: opentelemetry
      timerType: histogram
      listenAddress: "{{ topology_endpoints.temporal.endpoints.metrics.address }}"

services:
  frontend:
    rpc:
      grpcPort: {{ topology_endpoints.temporal.endpoints.frontend_grpc.port }}
      membershipPort: {{ topology_endpoints.temporal.endpoints.frontend_membership.port }}
      bindOnIP: "{{ topology_endpoints.temporal.host }}"
      httpPort: {{ topology_endpoints.temporal.endpoints.frontend_http.port }}
  internal-frontend:
    rpc:
      grpcPort: {{ topology_endpoints.temporal.endpoints.internal_frontend_grpc.port }}
      membershipPort: {{ topology_endpoints.temporal.endpoints.internal_membership.port }}
      bindOnIP: "{{ topology_endpoints.temporal.host }}"
      httpPort: {{ topology_endpoints.temporal.endpoints.internal_frontend_http.port }}
  history:
    rpc:
      grpcPort: {{ topology_endpoints.temporal.endpoints.history_grpc.port }}
      membershipPort: {{ topology_endpoints.temporal.endpoints.history_membership.port }}
      bindOnIP: "{{ topology_endpoints.temporal.host }}"
  matching:
    rpc:
      grpcPort: {{ topology_endpoints.temporal.endpoints.matching_grpc.port }}
      membershipPort: {{ topology_endpoints.temporal.endpoints.matching_membership.port }}
      bindOnIP: "{{ topology_endpoints.temporal.host }}"
  worker:
    rpc:
      grpcPort: {{ topology_clusters.temporal.worker.grpc_port }}
      membershipPort: {{ topology_endpoints.temporal.endpoints.worker_membership.port }}
      bindOnIP: "{{ topology_endpoints.temporal.host }}"

clusterMetadata:
  enableGlobalNamespace: false
  failoverVersionIncrement: 10
  masterClusterName: active
  currentClusterName: active
  clusterInformation:
    active:
      enabled: true
      initialFailoverVersion: 1
      rpcName: frontend
      rpcAddress: "{{ topology_endpoints.temporal.endpoints.frontend_grpc.address }}"
      httpAddress: "{{ topology_endpoints.temporal.endpoints.frontend_http.address }}"

dcRedirectionPolicy:
  policy: noop

archival:
  history:
    state: disabled
    enableRead: false
  visibility:
    state: disabled
    enableRead: false

namespaceDefaults:
  archival:
    history:
      state: disabled
    visibility:
      state: disabled

dynamicConfigClient:
  filepath: "{{ temporal_dynamic_config_path }}"
  pollInterval: 60s
