#!/usr/sbin/nft -f
# OpenBao is a loopback-only KMS and secrets backend. External access must traverse secrets-service.

table inet verself_openbao
delete table inet verself_openbao

table inet verself_openbao {
    chain input {
        type filter hook input priority filter; policy accept;

        tcp dport { {{ topology_endpoints.openbao.endpoints.api.port }}, {{ topology_endpoints.openbao.endpoints.cluster.port }} } iifname != "lo" drop
    }

    chain output {
        type filter hook output priority filter; policy accept;

        ct state established,related accept
        meta skuid != openbao accept

        meta l4proto != tcp meta l4proto != udp accept
        oifname "lo" tcp dport 443 accept
        oifname "lo" tcp dport {{ spire_bundle_endpoint_bind_port }} accept

        drop
    }
}
