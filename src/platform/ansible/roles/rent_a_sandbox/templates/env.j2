NODE_ENV=production
PORT={{ services.rent_a_sandbox.port }}
HOST=127.0.0.1
OTEL_SERVICE_NAME=rent-a-sandbox
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ services.otelcol.host }}:{{ services.otelcol.http_port }}
AUTH_ISSUER_URL={{ rent_a_sandbox_auth_issuer_url }}
AUTH_CLIENT_ID={{ rent_a_sandbox_client_id }}
AUTH_DATABASE_URL=postgresql://frontend_auth:{{ frontend_auth_sessions_pg_password }}@{{ services.postgresql.host }}:{{ services.postgresql.port }}/frontend_auth
AUTH_SESSION_SECRET={{ rent_a_sandbox_auth_session_secret }}
SANDBOX_RENTAL_SERVICE_BASE_URL=http://{{ services.sandbox_rental.host }}:{{ services.sandbox_rental.port }}
ELECTRIC_URL=http://{{ services.electric.host }}:{{ services.electric.port }}
