[Unit]
Description=Rent-a-Sandbox Frontend (TanStack Start)
After=forge-metal-firewall.target network.target sandbox-rental-service.service identity-service.service electric.service
Requires=forge-metal-firewall.target
Wants=sandbox-rental-service.service identity-service.service electric.service

[Service]
Type=simple
User={{ rent_a_sandbox_runtime_user }}
Group={{ rent_a_sandbox_runtime_group }}
WorkingDirectory={{ rent_a_sandbox_app_dir }}
EnvironmentFile=/etc/rent-a-sandbox/env
ExecStart={{ fm_bin }}/node --import ./instrumentation.mts .output/server/index.mjs
Restart=on-failure
RestartSec=5
Environment=PATH={{ fm_bin }}:/usr/bin:/bin
Environment=HOME={{ rent_a_sandbox_state_dir }}
CapabilityBoundingSet=
ProtectHome=true
ProtectSystem=strict
ReadWritePaths={{ rent_a_sandbox_state_dir }}
PrivateDevices=true
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
LockPersonality=true
NoNewPrivileges=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictRealtime=true
RestrictSUIDSGID=true
SystemCallArchitectures=native
UMask=0077

[Install]
WantedBy=multi-user.target
