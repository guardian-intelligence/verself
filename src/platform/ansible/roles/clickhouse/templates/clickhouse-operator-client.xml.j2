<config>
    <secure>1</secure>
    <host>{{ topology_endpoints.clickhouse.host }}</host>
    <port>{{ topology_endpoints.clickhouse.endpoints.native_tls.port }}</port>
    <openSSL>
        <client>
            <certificateFile>{{ clickhouse_operator_spiffe_dir }}/svid.pem</certificateFile>
            <privateKeyFile>{{ clickhouse_operator_spiffe_dir }}/svid_key.pem</privateKeyFile>
            <caConfig>{{ clickhouse_operator_ca_path }}</caConfig>
            <cacheSessions>true</cacheSessions>
            <disableProtocols>sslv2,sslv3</disableProtocols>
            <preferServerCiphers>true</preferServerCiphers>
            <invalidCertificateHandler>
                <name>RejectCertificateHandler</name>
            </invalidCertificateHandler>
        </client>
    </openSSL>
</config>
