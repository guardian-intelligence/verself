{
  "name": "Billing Service",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "Heartbeat (%)",
      "x": 0, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat('uptime (avg: ', toString(round(avg_pct, 1)), '%)') as series, heartbeat_pct FROM (SELECT *, avg(heartbeat_pct) OVER () as avg_pct FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, 100 as heartbeat_pct FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' AND ResourceAttributes['process.executable.name'] = 'billing-service' GROUP BY __hdx_time_bucket)) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "number", "suffix": "%"}
      }
    },
    {
      "name": "Memory (RSS)",
      "x": 4, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, avg(Value) as bytes FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' AND ResourceAttributes['process.executable.name'] = 'billing-service' GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "CPU (cores)",
      "x": 8, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT ts as __hdx_time_bucket, round(sum(delta) / greatest(max(span), 1), 4) as cpu_cores FROM (SELECT $__timeInterval(TimeUnix) as ts, ResourceAttributes['process.pid'] as pid, Attributes['state'] as state, max(Value) - min(Value) as delta, dateDiff('second', min(TimeUnix), max(TimeUnix)) as span FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.cpu.time' AND ResourceAttributes['process.executable.name'] = 'billing-service' GROUP BY ts, pid, state) GROUP BY ts ORDER BY ts",
        "fillNulls": true
      }
    },
    {
      "name": "Process I/O (bytes/s)",
      "x": 0, "y": 9, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, greatest(round((val_last - val_prev) / greatest(dateDiff('second', ts_prev, __hdx_time_bucket), 1), 0), 0) as bytes_per_sec, direction FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['direction'] as direction, argMax(Value, TimeUnix) as val_last, lagInFrame(argMax(Value, TimeUnix)) OVER (PARTITION BY Attributes['direction'] ORDER BY $__timeInterval(TimeUnix)) as val_prev, lagInFrame($__timeInterval(TimeUnix)) OVER (PARTITION BY Attributes['direction'] ORDER BY $__timeInterval(TimeUnix)) as ts_prev FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.disk.io' AND ResourceAttributes['process.executable.name'] = 'billing-service' GROUP BY __hdx_time_bucket, direction) WHERE val_prev IS NOT NULL ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Log Volume by Severity",
      "x": 4, "y": 9, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, SeverityText as severity, count() as cnt FROM default.otel_logs WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'billing-service' GROUP BY __hdx_time_bucket, severity ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    },
    {
      "name": "Log Error Rate (%)",
      "x": 8, "y": 9, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat('error rate (avg: ', toString(round(avg_pct, 2)), '%)') as series, error_pct FROM (SELECT *, avg(error_pct) OVER () as avg_pct FROM (SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, round(countIf(SeverityText IN ('ERROR', 'FATAL')) / greatest(count(), 1) * 100, 2) as error_pct FROM default.otel_logs WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'billing-service' GROUP BY __hdx_time_bucket)) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "number", "suffix": "%"}
      }
    },
    {
      "name": "Billing Windows by State",
      "x": 0, "y": 18, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT toStartOfInterval(created_at, INTERVAL 1 hour) as __hdx_time_bucket, state, count() as cnt FROM forge_metal.billing_windows_pg WHERE created_at >= now() - INTERVAL 7 DAY GROUP BY __hdx_time_bucket, state ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    },
    {
      "name": "Recent Billing Windows",
      "x": 4, "y": 18, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "table",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT created_at, window_id, org_id, product_id, source_type, source_ref, window_seq, state, reserved_quantity, actual_quantity, billed_charge_units, metering_projected_at FROM forge_metal.billing_windows_pg ORDER BY created_at DESC LIMIT 20"
      }
    },
    {
      "name": "Worker Task Queue Depth",
      "x": 8, "y": 18, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, countIf(Body LIKE '%dispatch%') as dispatched, countIf(Body LIKE '%completed%' OR Body LIKE '%success%') as completed, countIf(Body LIKE '%fail%' OR Body LIKE '%error%') as failed FROM default.otel_logs WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'billing-service' GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    }
  ]
}
