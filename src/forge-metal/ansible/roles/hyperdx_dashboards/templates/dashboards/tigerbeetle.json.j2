{
  "name": "TigerBeetle",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "Memory (RSS)",
      "x": 0, "y": 0, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, avg(Value) as bytes FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' AND ResourceAttributes['process.executable.name'] = 'tigerbeetle' GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "CPU (cores)",
      "x": 6, "y": 0, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT ts as __hdx_time_bucket, round(sum(delta) / greatest(max(span), 1), 4) as cpu_cores FROM (SELECT $__timeInterval(TimeUnix) as ts, ResourceAttributes['process.pid'] as pid, Attributes['state'] as state, max(Value) - min(Value) as delta, dateDiff('second', min(TimeUnix), max(TimeUnix)) as span FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.cpu.time' AND ResourceAttributes['process.executable.name'] = 'tigerbeetle' GROUP BY ts, pid, state) GROUP BY ts ORDER BY ts",
        "fillNulls": true
      }
    },
    {
      "name": "Committed Ops/s",
      "x": 0, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, greatest(round((op_last - op_prev) / greatest(dateDiff('second', ts_prev, __hdx_time_bucket), 1), 1), 0) as ops_per_sec FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, argMax(Value, TimeUnix) as op_last, lagInFrame(argMax(Value, TimeUnix)) OVER (ORDER BY $__timeInterval(TimeUnix)) as op_prev, lagInFrame($__timeInterval(TimeUnix)) OVER (ORDER BY $__timeInterval(TimeUnix)) as ts_prev FROM default.otel_metrics_gauge WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'tb.replica_op' GROUP BY __hdx_time_bucket) WHERE op_prev IS NOT NULL ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    },
    {
      "name": "Request Latency p100 (ms)",
      "x": 6, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, replaceAll(Attributes['operation'], 'Operation.', '') as operation, round(max(Value) / 1000, 2) as latency_ms FROM default.otel_metrics_gauge WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'tb.replica_request_us.max' AND Attributes['operation'] NOT IN ('Operation.register', 'Operation.pulse') GROUP BY __hdx_time_bucket, operation ORDER BY __hdx_time_bucket",
        "fillNulls": false
      }
    },
    {
      "name": "Grid Cache Hit Rate",
      "x": 0, "y": 18, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, round(sumIf(Value, MetricName = 'tb.grid_cache_hits') / greatest(sumIf(Value, MetricName = 'tb.grid_cache_hits') + sumIf(Value, MetricName = 'tb.grid_cache_misses'), 1), 4) as hit_rate FROM default.otel_metrics_gauge WHERE $__timeFilter_ms(TimeUnix) AND MetricName IN ('tb.grid_cache_hits', 'tb.grid_cache_misses') GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "percent"}
      }
    },
    {
      "name": "All StatsD Metrics (tb.*)",
      "x": 6, "y": 18, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "table",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT MetricName, count() as samples, round(avg(Value), 2) as avg_value, round(max(Value), 2) as max_value FROM default.otel_metrics_gauge WHERE $__timeFilter_ms(TimeUnix) AND MetricName LIKE 'tb.%' GROUP BY MetricName ORDER BY MetricName"
      }
    }
  ]
}