load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "layers",
    srcs = [
        "layers.go",
        "safeconv.go",
    ],
    importpath = "github.com/verself/deployment-tools/internal/layers",
    visibility = ["//src/deployment-tools:__subpackages__"],
    deps = [
        "//src/deployment-tools/internal/ansible",
        "//src/deployment-tools/internal/bazelbuild",
        "//src/deployment-tools/internal/chwriter",
        "//src/deployment-tools/internal/ledger",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

alias(
    name = "go_default_library",
    actual = ":layers",
    visibility = ["//src/deployment-tools:__subpackages__"],
)
