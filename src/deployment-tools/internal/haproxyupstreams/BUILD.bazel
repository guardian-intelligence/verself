load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "haproxyupstreams",
    srcs = ["haproxyupstreams.go"],
    importpath = "github.com/verself/deployment-tools/internal/haproxyupstreams",
    visibility = ["//src/deployment-tools:__subpackages__"],
    deps = [
        "//src/deployment-tools/internal/nomadclient",
        "//src/deployment-tools/internal/sshtun",
        "//src/host-configuration/edgecontract",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

go_test(
    name = "haproxyupstreams_test",
    srcs = ["haproxyupstreams_test.go"],
    embed = [":haproxyupstreams"],
    deps = [
        "//src/deployment-tools/internal/nomadclient",
    ],
)
