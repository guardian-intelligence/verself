    importpath = "github.com/verself/deployment-tools/cmd/verself-deploy",
    visibility = ["//visibility:private"],
    deps = [
        "//src/deployment-tools/internal/ansible",
        "//src/deployment-tools/internal/bazelbuild",
        "//src/deployment-tools/internal/deploydb",
        "//src/deployment-tools/internal/garage",
        "//src/deployment-tools/internal/haproxyupstreams",
        "//src/deployment-tools/internal/identity",
        "//src/deployment-tools/internal/nomadclient",
        "//src/deployment-tools/internal/render",
        "//src/deployment-tools/internal/runtime",
        "//src/deployment-tools/internal/sshtun",
        "//src/deployment-tools/internal/supplychain",
        "@in_gopkg_yaml_v3//:yaml_v3",
