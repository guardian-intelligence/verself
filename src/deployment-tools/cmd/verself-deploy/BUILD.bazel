load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "verself-deploy_lib",
    srcs = [
        "ansible_run.go",
        "artifacts.go",
        "main.go",
        "nomad_deploy_all.go",
        "nomad_submit.go",
        "paths.go",
        "run.go",
        "safeconv.go",
        "security_patch.go",
        "supply_chain.go",
        "viteplus_install.go",
        "with_otel.go",
