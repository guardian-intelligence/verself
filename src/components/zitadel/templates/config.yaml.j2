# Zitadel configuration.
# Managed by Ansible — do not edit manually.

Log:
  Level: info
  Formatter:
    Format: json

Port: {{ zitadel_http_port }}
ExternalDomain: {{ zitadel_domain }}
ExternalPort: 443
ExternalSecure: true

TLS:
  Enabled: false

Database:
  postgres:
    Host: {{ postgresql_host }}
    Port: {{ postgresql_port }}
    Database: zitadel
    User:
      Username: zitadel
      Password: "{{ zitadel_db_password }}"
      SSL:
        Mode: disable
    Admin:
      Username: postgres
      Password: "{{ postgresql_admin_password }}"
      SSL:
        Mode: disable
    MaxOpenConns: 10
    MaxIdleConns: 5
    MaxConnLifetime: 30m

DefaultInstance:
  Features:
    LoginV2:
      # Login V2 is a separate Next.js app (zitadel-login), not embedded in the
      # Zitadel Go binary. Until deployed as a separate service, use embedded Login V1.
      Required: false
  DomainPolicy:
    # Sender domain (notify.X) differs from Zitadel's ExternalDomain (auth.X).
    SMTPSenderAddressMatchesInstanceDomain: false
  SMTPConfiguration:
    SMTP:
      Host: "{{ zitadel_smtp_host }}"
      User: "{{ zitadel_smtp_user }}"
      Password: "{{ resend_api_key }}"
    TLS: {{ zitadel_smtp_tls | lower }}
    From: "{{ resend_sender_address }}"
    FromName: "{{ resend_sender_name }}"
  LabelPolicy:
    DisableWatermark: true
    HideLoginNameSuffix: true
  LoginPolicy:
    AllowRegister: false

Machine:
  Identification:
    PrivateIp:
      Enabled: false
    Hostname:
      Enabled: true

Instrumentation:
  Trace:
    Exporter:
      Type: grpc
      Endpoint: {{ zitadel_otelcol_otlp_grpc_address }}
      Insecure: true
    Fraction: 1
  Metrics:
    Enabled: true
