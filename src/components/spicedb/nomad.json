{
  "Job": {
    "Datacenters": [
      "dc1"
    ],
    "ID": "spicedb",
    "Meta": {},
    "Name": "spicedb",
    "TaskGroups": [
      {
        "Count": 1,
        "Name": "spicedb",
        "Networks": [
          {
            "DynamicPorts": [
              {
                "HostNetwork": "loopback",
                "Label": "grpc"
              },
              {
                "HostNetwork": "loopback",
                "Label": "metrics"
              }
            ],
            "Mode": "host"
          }
        ],
        "Tasks": [
          {
            "Config": {
              "args": [
                "datastore",
                "migrate",
                "head",
                "--datastore-engine",
                "postgres",
                "--datastore-conn-uri",
                "postgres://spicedb@/spicedb?host=/var/run/postgresql\u0026sslmode=disable\u0026application_name=spicedb",
                "--log-format",
                "json",
                "--skip-release-check"
              ],
              "command": "/opt/verself/profile/bin/spicedb"
            },
            "Driver": "raw_exec",
            "Env": {
              "HOME": "/tmp",
              "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4317",
              "OTEL_RESOURCE_ATTRIBUTES": "verself.supervisor=nomad",
              "OTEL_SERVICE_NAME": "spicedb-migration",
              "VERSELF_SUPERVISOR": "nomad"
            },
            "Lifecycle": {
              "Hook": "prestart",
              "Sidecar": false
            },
            "Name": "spicedb-migrate",
            "Resources": {
              "CPU": 100,
              "MemoryMB": 256
            },
            "User": "spicedb"
          },
          {
            "Config": {
              "args": [
                "serve",
                "--datastore-engine=postgres",
                "--datastore-conn-uri=postgres://spicedb@/spicedb?host=/var/run/postgresql\u0026sslmode=disable\u0026application_name=spicedb",
                "--datastore-conn-pool-read-max-open=8",
                "--datastore-conn-pool-read-min-open=1",
                "--datastore-conn-pool-write-max-open=4",
                "--datastore-conn-pool-write-min-open=1",
                "--grpc-addr=127.0.0.1:${NOMAD_PORT_grpc}",
                "--metrics-addr=127.0.0.1:${NOMAD_PORT_metrics}",
                "--http-enabled=false",
                "--telemetry-endpoint=",
                "--skip-release-check",
                "--log-format=json"
              ],
              "command": "/opt/verself/profile/bin/spicedb"
            },
            "Driver": "raw_exec",
            "Env": {
              "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4317",
              "OTEL_RESOURCE_ATTRIBUTES": "verself.supervisor=nomad",
              "OTEL_SERVICE_NAME": "spicedb",
              "VERSELF_SUPERVISOR": "nomad"
            },
            "KillSignal": "SIGTERM",
            "KillTimeout": 30000000000,
            "Name": "spicedb",
            "Resources": {
              "CPU": 500,
              "MemoryMB": 1024
            },
            "RestartPolicy": {
              "Attempts": 3,
              "Delay": 15000000000,
              "Interval": 300000000000,
              "Mode": "delay"
            },
            "Services": [
              {
                "AddressMode": "auto",
                "Checks": [
                  {
                    "Interval": 1000000000,
                    "Name": "spicedb-grpc-tcp",
                    "PortLabel": "grpc",
                    "Timeout": 3000000000,
                    "Type": "tcp"
                  }
                ],
                "Name": "spicedb-grpc",
                "PortLabel": "grpc",
                "Provider": "nomad"
              },
              {
                "AddressMode": "auto",
                "Checks": [
                  {
                    "Interval": 1000000000,
                    "Name": "spicedb-metrics-http",
                    "Path": "/metrics",
                    "PortLabel": "metrics",
                    "Timeout": 3000000000,
                    "Type": "http"
                  }
                ],
                "Name": "spicedb-metrics",
                "PortLabel": "metrics",
                "Provider": "nomad"
              }
            ],
            "Templates": [
              {
                "ChangeMode": "restart",
                "DestPath": "secrets/spicedb.env",
                "Envvars": true,
                "SourcePath": "/etc/spicedb/spicedb.env"
              }
            ],
            "User": "spicedb"
          }
        ],
        "Update": {
          "AutoPromote": true,
          "AutoRevert": true,
          "Canary": 1,
          "HealthCheck": "checks",
          "HealthyDeadline": 300000000000,
          "MaxParallel": 1,
          "MinHealthyTime": 3000000000,
          "ProgressDeadline": 600000000000
        }
      }
    ],
    "Type": "service"
  }
}
