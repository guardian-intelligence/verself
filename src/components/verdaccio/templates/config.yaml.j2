# Verdaccio npm registry mirror — managed by Ansible.
# See docs/research/verdaccio/ for security hardening rationale.

storage: {{ verdaccio_storage_path | default('/var/lib/verdaccio/storage') }}

auth:
  htpasswd:
    file: /etc/verdaccio/htpasswd
    algorithm: bcrypt
    rounds: 10
    max_users: 0

web:
  enable: false

uplinks:
  npmjs:
    url: https://registry.npmjs.org/
    cache: true
    maxage: 30m
    strict_ssl: true

packages:
  '**':
    access: $all
    publish: $nobody
    unpublish: $nobody
    proxy: npmjs

max_body_size: 100mb
listen: {{ verdaccio_listen_host }}:{{ verdaccio_http_port }}

# Supply-chain gating via @verdaccio/package-filter (bundled with Verdaccio
# >= 6.4.0). The plugin rewrites uplink manifests before they reach clients:
# filtered versions disappear from package metadata resolution.
#
# Supported rules: age quarantine (minAgeDays), date freeze (dateThreshold),
# and block/allow lists keyed by scope, package, or semver range. License
# blocklists and CVE severity gating are NOT supported by this plugin — those
# live in separate tooling (Socket, Snyk, Dependabot, a NodeSecure scanner
# gate in CI). Don't add dead config here claiming otherwise.
#
# Plugin ships on a prerelease track (13.0.0-next-*), per Verdaccio's 6.4.0
# notes asking for testing. Config keys below (block/allow/minAgeDays/
# dateThreshold) are the only keys the plugin recognises — pin
# verdaccio_version in group_vars when upgrading so grammar drift is caught
# in review, not at runtime.
#
# Failure-mode posture: misconfiguration throws at plugin construction and
# Verdaccio refuses to start (fail-closed on config). Runtime filter errors
# are caught by Verdaccio core (storage.js _applyFilters) and the unfiltered
# manifest is served (fail-open at runtime). There is no knob to invert
# either posture; we accept it because the plugin is pure in-memory manifest
# transformation with no IO that could legitimately fail.
filters:
  '@verdaccio/package-filter':
    minAgeDays: 3

# Structured JSON logs over stdout → journald → otelcol → ClickHouse.
# Verdaccio uses pino under the hood; format: json produces the native
# pino shape ({level,time,msg,sub,request,status,bytes,...}) which the
# otelcol journald/verdaccio receiver parses into LogAttributes + maps
# pino numeric levels (http=25, info=30, warn=40, error=50, fatal=60) to
# OTel SeverityText. Level http keeps per-request access logs; dropping
# to info would silence them.
#
# redact: paths come from Verdaccio's own default-config example. Pino
# redact runs before the JSON hits stdout, so credentials never land in
# journald or ClickHouse even if an upstream uplink reflects them back.
# The otelcol pipeline drops the entire `req` object post-parse for
# defense-in-depth; redact here is the primary line.
log:
  type: stdout
  format: json
  level: http
  redact:
    paths:
      - req.header.authorization
      - req.header.cookie
    censor: '<redacted>'
