load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "temporal-schema_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/temporal-platform/cmd/temporal-schema",
    visibility = ["//visibility:private"],
    deps = [
        "//src/components/temporal-platform/internal/pgsocket",
        "//src/tools/observability/go/otel",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_temporal_go_server//common/config",
        "@io_temporal_go_server//common/log",
        "@io_temporal_go_server//common/persistence/sql/sqlplugin/postgresql",
        "@io_temporal_go_server//tools/common/schema",
        "@io_temporal_go_server//tools/sql",
    ],
