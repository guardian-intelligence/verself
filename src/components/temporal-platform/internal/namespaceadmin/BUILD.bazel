load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "namespaceadmin",
    srcs = ["namespaceadmin.go"],
    importpath = "github.com/verself/temporal-platform/internal/namespaceadmin",
    visibility = ["//src/components/temporal-platform:__subpackages__"],
    deps = [
        "@io_temporal_go_api//serviceerror",
        "@io_temporal_go_api//workflowservice/v1:workflowservice",
        "@io_temporal_go_sdk//client",
        "@org_golang_google_protobuf//types/known/durationpb",
