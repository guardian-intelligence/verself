load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "spiffeauth",
    srcs = ["spiffeauth.go"],
    importpath = "github.com/verself/temporal-platform/internal/spiffeauth",
    visibility = ["//src/components/temporal-platform:__subpackages__"],
    deps = [
        "@com_github_spiffe_go_spiffe_v2//svid/x509svid",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//attribute",
        "@io_opentelemetry_go_otel//codes",
        "@io_temporal_go_server//common/authorization",
        "@org_golang_google_grpc//:grpc",
    ],
)

alias(
    name = "go_default_library",
    actual = ":spiffeauth",
    visibility = ["//src/components/temporal-platform:__subpackages__"],
)
