load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "sdkclient",
    srcs = ["client.go"],
    importpath = "github.com/verself/temporal-platform/sdkclient",
    visibility = ["//visibility:public"],
    deps = [
        "//src/services/auth-middleware/workload",
        "//src/services/service-runtime/go/envconfig",
        "//src/components/temporal-platform/internal/temporallog",
        "@com_github_spiffe_go_spiffe_v2//spiffetls/tlsconfig",
        "@com_github_spiffe_go_spiffe_v2//workloadapi",
        "@io_opentelemetry_go_contrib_instrumentation_google_golang_org_grpc_otelgrpc//:otelgrpc",
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//propagation",
        "@io_temporal_go_sdk//client",
        "@io_temporal_go_sdk//interceptor",
        "@io_temporal_go_sdk_contrib_opentelemetry//:opentelemetry",
        "@org_golang_google_grpc//:grpc",
    ],
)

alias(
    name = "go_default_library",
    actual = ":sdkclient",
    visibility = ["//visibility:public"],
)
