load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "verself-temporal-server_lib",
    srcs = ["main.go"],
    importpath = "github.com/verself/temporal-platform/cmd/verself-temporal-server",
    visibility = ["//visibility:private"],
    deps = [
        "//src/service-runtime/go/envconfig",
        "//src/observability/go/otel",
        "//src/temporal-platform/internal/pgsocket",
        "//src/temporal-platform/internal/spiffeauth",
        "//src/temporal-platform/internal/tlsprovider",
        "@io_temporal_go_server//common/authorization",
        "@io_temporal_go_server//common/config",
        "@io_temporal_go_server//temporal",
    ],
)

go_binary(
    name = "verself-temporal-server",
    embed = [":verself-temporal-server_lib"],
    visibility = ["//visibility:public"],
)
