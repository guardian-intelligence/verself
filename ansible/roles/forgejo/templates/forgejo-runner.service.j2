[Unit]
Description=Forgejo Actions Runner
After=forgejo.service
Requires=forgejo.service

[Service]
Type=simple
User=bench-ci
ExecStart={{ fm_bin }}/forgejo-runner daemon --config /etc/forgejo/runner-config.yaml
Restart=on-failure
WorkingDirectory=/var/lib/bench-ci
Environment=PATH={{ fm_bin }}:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
