{
  "name": "Host Process Metrics",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "CPU Utilization %",
      "x": 0, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT ts as __hdx_time_bucket, round(100 * (1 - sum(idle_delta) / sum(total_delta)), 1) as cpu_pct, 100 as _max FROM (SELECT $__timeInterval(TimeUnix) as ts, Attributes['cpu'] as cpu, Attributes['state'] as state, max(Value) - min(Value) as delta, if(state = 'idle', delta, 0) as idle_delta, delta as total_delta FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.cpu.time' GROUP BY ts, cpu, state) GROUP BY ts ORDER BY ts",
        "fillNulls": true,
        "numberFormat": {"output": "percent"}
      }
    },
    {
      "name": "Memory Utilization %",
      "x": 4, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT ts as __hdx_time_bucket, round(100 * (1 - (free_b / total_b)), 1) as mem_pct, 100 as _max FROM (SELECT $__timeInterval(TimeUnix) as ts, avgIf(Value, Attributes['state'] = 'free') as free_b, sum(Value) / count(DISTINCT TimeUnix) as total_b FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY ts) ORDER BY ts",
        "fillNulls": true,
        "numberFormat": {"output": "percent"}
      }
    },
    {
      "name": "Storage Utilization",
      "x": 8, "y": 0, "w": 4, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT * FROM (SELECT __hdx_time_bucket, concat(volume, ' (avg: ', formatReadableSize(vol_avg), ')') as volume, bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['mountpoint'] as volume, avgIf(Value, Attributes['state'] = 'used') as bytes, avg(avgIf(Value, Attributes['state'] = 'used')) OVER (PARTITION BY Attributes['mountpoint']) as vol_avg FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.filesystem.usage' AND Attributes['mountpoint'] IN ('/', '/benchpool') GROUP BY __hdx_time_bucket, volume) UNION ALL SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, 'capacity' as volume, max(total_per_mp) as bytes FROM (SELECT TimeUnix, Attributes['mountpoint'] as mp, sum(Value) as total_per_mp FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.filesystem.usage' AND Attributes['mountpoint'] IN ('/', '/benchpool') GROUP BY TimeUnix, mp) GROUP BY __hdx_time_bucket) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Process Memory (RSS)",
      "x": 0, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat(process, ' (avg: ', formatReadableSize(process_avg), ')') as series, bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, ResourceAttributes['process.executable.name'] as process, avg(Value) as bytes, avg(avg(Value)) OVER (PARTITION BY ResourceAttributes['process.executable.name']) as process_avg FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' GROUP BY __hdx_time_bucket, process) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Process CPU Time (rate)",
      "x": 6, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat(process, ' (avg: ', toString(round(process_avg, 2)), 's)') as series, cpu_seconds FROM (SELECT ts as __hdx_time_bucket, process, sum(delta) as cpu_seconds, avg(sum(delta)) OVER (PARTITION BY process) as process_avg FROM (SELECT $__timeInterval(TimeUnix) as ts, ResourceAttributes['process.executable.name'] as process, Attributes['state'] as state, max(Value) - min(Value) as delta FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.cpu.time' GROUP BY ts, process, state) GROUP BY ts, process) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "time"}
      }
    },
    {
      "name": "System Load Averages",
      "x": 0, "y": 18, "w": 6, "h": 9,
      "config": {
        "displayType": "line",
        "sourceId": "{{ _hdx_metric_source_id }}",
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "Value",
            "metricName": "system.cpu.load_average.1m",
            "metricType": "gauge"
          }
        ],
        "fillNulls": true
      }
    },
    {
      "name": "System Memory by State",
      "x": 6, "y": 18, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat(state, ' (avg: ', formatReadableSize(state_avg), ')') as series, bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['state'] as state, avg(Value) as bytes, avg(avg(Value)) OVER (PARTITION BY Attributes['state']) as state_avg FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY __hdx_time_bucket, state) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Current Process Memory (live snapshot)",
      "x": 0, "y": 27, "w": 12, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "table",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT ResourceAttributes['process.executable.name'] as process, ResourceAttributes['process.pid'] as pid, ResourceAttributes['process.command'] as command, formatReadableSize(argMax(Value, TimeUnix)) as mem, round(argMax(Value, TimeUnix) / 1048576, 1) as mem_mb FROM default.otel_metrics_sum WHERE TimeUnix >= now() - INTERVAL 5 SECOND AND MetricName = 'process.memory.usage' GROUP BY process, pid, command ORDER BY mem_mb DESC"
      }
    }
  ]
}
