{
  "name": "Host Process Metrics",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "Process Memory (RSS)",
      "x": 0, "y": 0, "w": 6, "h": 9,
      "config": {
        "displayType": "line",
        "sourceId": "{{ _hdx_metric_source_id }}",
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "Value",
            "metricName": "process.memory.usage",
            "metricType": "sum"
          }
        ],
        "groupBy": "ResourceAttributes['process.executable.name']",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Process CPU Time (rate)",
      "x": 6, "y": 0, "w": 6, "h": 9,
      "config": {
        "displayType": "line",
        "sourceId": "{{ _hdx_metric_source_id }}",
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "metricName": "process.cpu.time",
            "metricType": "sum",
            "periodAggFn": "delta"
          }
        ],
        "groupBy": "ResourceAttributes['process.executable.name']",
        "fillNulls": true,
        "numberFormat": {"output": "time"}
      }
    },
    {
      "name": "System Load Averages",
      "x": 0, "y": 9, "w": 6, "h": 9,
      "config": {
        "displayType": "line",
        "sourceId": "{{ _hdx_metric_source_id }}",
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "Value",
            "metricName": "system.cpu.load_average.1m",
            "metricType": "gauge"
          }
        ],
        "fillNulls": true
      }
    },
    {
      "name": "System Memory by State",
      "x": 6, "y": 9, "w": 6, "h": 9,
      "config": {
        "displayType": "line",
        "sourceId": "{{ _hdx_metric_source_id }}",
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "Value",
            "metricName": "system.memory.usage",
            "metricType": "sum"
          }
        ],
        "groupBy": "Attributes['state']",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Current Process Memory (live snapshot)",
      "x": 0, "y": 18, "w": 12, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "table",
        "connectionId": "{{ _hdx_connection_id }}",
        "sqlTemplate": "SELECT ResourceAttributes['process.executable.name'] as process, ResourceAttributes['process.pid'] as pid, ResourceAttributes['process.command'] as command, formatReadableSize(argMax(Value, TimeUnix)) as mem, round(argMax(Value, TimeUnix) / 1048576, 1) as mem_mb FROM default.otel_metrics_sum WHERE TimeUnix >= now() - INTERVAL 5 SECOND AND MetricName = 'process.memory.usage' GROUP BY process, pid, command ORDER BY mem_mb DESC"
      }
    }
  ]
}
