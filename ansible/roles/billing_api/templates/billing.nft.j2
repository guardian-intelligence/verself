#!/usr/sbin/nft -f
# Billing service egress restrictions.
# The billing-server binds 127.0.0.1:4242 (loopback-only, no input rules needed).
# Caddy terminates TLS and reverse-proxies /webhooks/stripe to it.
# This table restricts the billing user's outbound traffic to only what's required.

table inet forge_metal_billing
delete table inet forge_metal_billing

table inet forge_metal_billing {
    chain output {
        type filter hook output priority filter; policy accept;

        # Only constrain packets originating from the billing user.
        meta skuid != billing accept

        # Loopback covers TigerBeetle, PostgreSQL, ClickHouse.
        oifname "lo" accept

        # Established/related (return traffic for accepted connections).
        ct state established,related accept

        # Stripe API — HTTPS only.
        tcp dport 443 accept

        # DNS resolution for Stripe hostname.
        tcp dport 53 accept
        udp dport 53 accept

        drop
    }
}
