{
  "name": "Host Process Metrics",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "CPU Utilization %",
      "x": 0, "y": 0, "w": 3, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT ts as __hdx_time_bucket, round(1 - sum(idle_delta) / sum(total_delta), 4) as cpu_pct, 1 as _max FROM (SELECT $__timeInterval(TimeUnix) as ts, Attributes['cpu'] as cpu, Attributes['state'] as state, max(Value) - min(Value) as delta, if(state = 'idle', delta, 0) as idle_delta, delta as total_delta FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.cpu.time' GROUP BY ts, cpu, state) GROUP BY ts ORDER BY ts",
        "fillNulls": true,
        "numberFormat": {"output": "percent"}
      }
    },
    {
      "name": "Memory Utilization %",
      "x": 3, "y": 0, "w": 3, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, series, pct FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, round(sumIf(Value, Attributes['state'] IN ('used', 'slab_unreclaimable')) / sum(Value), 4) as pct, 'committed' as series FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY __hdx_time_bucket UNION ALL SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, round(sumIf(Value, Attributes['state'] = 'free') / sum(Value), 4) as pct, 'free' as series FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY __hdx_time_bucket UNION ALL SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, round(sumIf(Value, Attributes['state'] = 'cached') / sum(Value), 4) as pct, 'cached' as series FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY __hdx_time_bucket) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "percent"}
      }
    },
    {
      "name": "Storage Utilization",
      "x": 6, "y": 0, "w": 3, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT * FROM (SELECT __hdx_time_bucket, concat(volume, ' (avg: ', formatReadableSize(vol_avg), ')') as volume, bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['mountpoint'] as volume, avgIf(Value, Attributes['state'] = 'used') as bytes, avg(avgIf(Value, Attributes['state'] = 'used')) OVER (PARTITION BY Attributes['mountpoint']) as vol_avg FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.filesystem.usage' AND Attributes['mountpoint'] IN ('/', '/benchpool') GROUP BY __hdx_time_bucket, volume) UNION ALL SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, 'capacity' as volume, max(total_per_mp) as bytes FROM (SELECT TimeUnix, Attributes['mountpoint'] as mp, sum(Value) as total_per_mp FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.filesystem.usage' AND Attributes['mountpoint'] IN ('/', '/benchpool') GROUP BY TimeUnix, mp) GROUP BY __hdx_time_bucket) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Network Overview",
      "x": 9, "y": 0, "w": 3, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, series, bytes FROM (SELECT __hdx_time_bucket, 'north (rx)' as series, toFloat64(sum(delta)) as bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['device'] as device, max(Value) - min(Value) as delta FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.network.io' AND Attributes['direction'] = 'receive' AND Attributes['device'] != 'lo' GROUP BY __hdx_time_bucket, device) GROUP BY __hdx_time_bucket UNION ALL SELECT __hdx_time_bucket, 'south (tx)' as series, toFloat64(sum(delta)) as bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, Attributes['device'] as device, max(Value) - min(Value) as delta FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.network.io' AND Attributes['direction'] = 'transmit' AND Attributes['device'] != 'lo' GROUP BY __hdx_time_bucket, device) GROUP BY __hdx_time_bucket UNION ALL SELECT $__timeInterval(event_time) as __hdx_time_bucket, 'east/west (ch)' as series, toFloat64(sum(read_bytes + written_bytes)) as bytes FROM system.query_log WHERE $__timeFilter_ms(event_time) AND type = 'QueryFinish' GROUP BY __hdx_time_bucket) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Memory",
      "x": 0, "y": 9, "w": 12, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, series, bytes FROM (SELECT __hdx_time_bucket, concat('slab (ZFS ARC) (avg: ', formatReadableSize(slab_avg), ')') as series, bytes FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, avgIf(Value, Attributes['state'] = 'slab_reclaimable') as bytes, avg(avgIf(Value, Attributes['state'] = 'slab_reclaimable')) OVER () as slab_avg FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'system.memory.usage' GROUP BY __hdx_time_bucket) UNION ALL SELECT __hdx_time_bucket, concat(process, ' (avg: ', formatReadableSize(process_avg), ')') as series, bytes FROM (SELECT __hdx_time_bucket, process, avg(point_total) as bytes, avg(avg(point_total)) OVER (PARTITION BY process) as process_avg FROM (SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, TimeUnix, if(startsWith(ResourceAttributes['process.executable.name'], 'kworker'), 'kworker', ResourceAttributes['process.executable.name']) as process, sum(Value) as point_total FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' GROUP BY __hdx_time_bucket, TimeUnix, process) GROUP BY __hdx_time_bucket, process)) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "byte"}
      }
    },
    {
      "name": "Process CPU (cores)",
      "x": 0, "y": 18, "w": 12, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, concat(process, ' (avg: ', toString(round(process_avg, 2)), ')') as series, cpu_cores FROM (SELECT ts as __hdx_time_bucket, process, round(sum(delta) / greatest(max(span), 1), 2) as cpu_cores, avg(round(sum(delta) / greatest(max(span), 1), 2)) OVER (PARTITION BY process) as process_avg FROM (SELECT $__timeInterval(TimeUnix) as ts, ResourceAttributes['process.executable.name'] as process, ResourceAttributes['process.pid'] as pid, Attributes['state'] as state, max(Value) - min(Value) as delta, dateDiff('second', min(TimeUnix), max(TimeUnix)) as span FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.cpu.time' GROUP BY ts, process, pid, state) GROUP BY ts, process) WHERE process_avg > 0 ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    },
    {
      "name": "Current Process Memory (live snapshot)",
      "x": 0, "y": 27, "w": 12, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "table",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT ResourceAttributes['process.executable.name'] as process, ResourceAttributes['process.pid'] as pid, ResourceAttributes['process.command'] as command, formatReadableSize(argMax(Value, TimeUnix)) as mem, round(argMax(Value, TimeUnix) / 1048576, 1) as mem_mb FROM default.otel_metrics_sum WHERE TimeUnix >= now() - INTERVAL 30 SECOND AND MetricName = 'process.memory.usage' GROUP BY process, pid, command ORDER BY mem_mb DESC"
      }
    }
  ]
}
