{
  "name": "Zitadel",
  "tags": ["infrastructure"],
  "tiles": [
    {
      "name": "OIDC Latency (p95 / p99)",
      "x": 0, "y": 0, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT __hdx_time_bucket, series, ms FROM (SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, 'p95' as series, quantile(0.95)(Duration / 1000000) as ms FROM default.otel_traces WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'zitadel' AND (SpanName LIKE '%/oauth/%' OR SpanName LIKE '%/oidc/%') AND Duration > 0 GROUP BY __hdx_time_bucket UNION ALL SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, 'p99' as series, quantile(0.99)(Duration / 1000000) as ms FROM default.otel_traces WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'zitadel' AND (SpanName LIKE '%/oauth/%' OR SpanName LIKE '%/oidc/%') AND Duration > 0 GROUP BY __hdx_time_bucket) ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "number", "suffix": " ms"}
      }
    },
    {
      "name": "OIDC Error Rate (%)",
      "x": 6, "y": 0, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, round(countIf(StatusCode = 'Error') / greatest(count(), 1) * 100, 2) as error_pct FROM default.otel_traces WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'zitadel' AND (SpanName LIKE '%/oauth/%' OR SpanName LIKE '%/oidc/%') GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true,
        "numberFormat": {"output": "number", "suffix": "%"}
      }
    },
    {
      "name": "Zitadel Heartbeat (samples/interval)",
      "x": 0, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(TimeUnix) as __hdx_time_bucket, count() as samples FROM default.otel_metrics_sum WHERE $__timeFilter_ms(TimeUnix) AND MetricName = 'process.memory.usage' AND ResourceAttributes['process.executable.name'] = 'zitadel' GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    },
    {
      "name": "Error Log Rate",
      "x": 6, "y": 9, "w": 6, "h": 9,
      "config": {
        "configType": "sql",
        "displayType": "line",
        "connectionId": "{{ hyperdx_dashboards_connection_id }}",
        "sqlTemplate": "SELECT $__timeInterval(Timestamp) as __hdx_time_bucket, count() as errors FROM default.otel_logs WHERE $__timeFilter_ms(Timestamp) AND ServiceName = 'zitadel' AND SeverityNumber >= 17 GROUP BY __hdx_time_bucket ORDER BY __hdx_time_bucket",
        "fillNulls": true
      }
    }
  ]
}
