# HyperDX production environment — managed by Ansible
NODE_ENV=production
HYPERDX_API_PORT={{ services.hyperdx.api_port }}
HYPERDX_APP_PORT={{ services.hyperdx.app_port }}
HYPERDX_OPAMP_PORT={{ services.hyperdx.opamp_port }}
HYPERDX_LOG_LEVEL=info
EXPRESS_SESSION_SECRET={{ hyperdx_session_secret }}
FRONTEND_URL=https://{{ hyperdx_domain }}
MONGO_URI=mongodb://{{ services.mongodb.host }}:{{ services.mongodb.port }}/hyperdx
PORT={{ services.hyperdx.api_port }}
OPAMP_PORT={{ services.hyperdx.opamp_port }}
SERVER_URL=http://{{ services.hyperdx.host }}:{{ services.hyperdx.api_port }}
OTEL_SERVICE_NAME=hdx-forge-metal
OTEL_EXPORTER_OTLP_ENDPOINT=http://{{ services.otelcol.host }}:{{ services.otelcol.http_port }}
USAGE_STATS_ENABLED=false
NODE_OPTIONS=--max-http-header-size=131072
DEFAULT_CONNECTIONS=[{"name":"forge-metal","host":"http://default:{{ clickhouse_password | urlencode }}@{{ services.clickhouse.host }}:{{ services.clickhouse.http_port }}"}]
