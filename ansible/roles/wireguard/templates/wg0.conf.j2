[Interface]
PrivateKey = {{ wireguard_private_key_material }}
Address = {{ wireguard_address }}/16
ListenPort = {{ wireguard_port }}

{% for peer in wireguard_peers | default([]) %}
[Peer]
PublicKey = {{ peer.public_key }}
Endpoint = {{ peer.endpoint }}:{{ wireguard_port }}
AllowedIPs = {{ peer.allowed_ip }}/32
PersistentKeepalive = 25
{% endfor %}
