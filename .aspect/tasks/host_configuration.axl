"""aspect host edit-secrets | npm-edge | operator-access-handoff

Bootstrap convergence and Nomad deployments do not own the operator-access
handoff. Pomerium is a manual host action because a bad change can move SSH
listeners and lock operators out.
"""

load(".aspect/lib/helpers.axl", "DEFAULT_SITE", "HOST_CONFIGURATION_DIR", "checked_spawn", "inventory_check", "ws_path")

def _edit_secrets_impl(ctx):
    return checked_spawn(
        ctx,
        "sops",
        [ws_path(ctx, HOST_CONFIGURATION_DIR, "sites/prod/secrets/host.sops.yml")],
        label = "sops edit host secrets",
    )

edit_secrets = task(
    implementation = _edit_secrets_impl,
    name = "edit-secrets",
    group = ["host"],
    summary = "Open encrypted host configuration secrets in $EDITOR via sops.",
)

def _host_playbook(ctx, site, playbook):
    rc = inventory_check(ctx, site)
    if rc != 0:
        return rc
    ansible_dir = ws_path(ctx, HOST_CONFIGURATION_DIR, "ansible")
    return checked_spawn(
        ctx,
        "ansible-playbook",
        [
            "-i",
            ws_path(ctx, HOST_CONFIGURATION_DIR, "sites/" + site + "/inventory.ini"),
            "playbooks/" + playbook,
            "-e",
            "verself_site=" + site,
        ],
        cwd = ansible_dir,
        label = "ansible-playbook " + playbook + " --site " + site,
    )

def _npm_edge_impl(ctx):
    site = ctx.args.site or DEFAULT_SITE
    for playbook in ["verdaccio.yml", "nftables.yml", "haproxy.yml"]:
        rc = _host_playbook(ctx, site, playbook)
        if rc != 0:
            return rc
    return 0

npm_edge = task(
    implementation = _npm_edge_impl,
    name = "npm-edge",
    group = ["host"],
    summary = "Converge Verdaccio, nftables, and HAProxy for the public npm registry edge.",
    args = {
        "site": args.string(default = "prod", description = "Deployment site."),
    },
)

def _operator_access_handoff_impl(ctx):
    if not ctx.args.confirm:
        ctx.std.io.stderr.write("ERROR: pass --confirm to run the Pomerium operator-access handoff\n")
        return 1
    site = ctx.args.site or "prod"
    ansible_dir = ws_path(ctx, HOST_CONFIGURATION_DIR, "ansible")
    return checked_spawn(
        ctx,
        "ansible-playbook",
        [
            "-i",
            ws_path(ctx, HOST_CONFIGURATION_DIR, "sites/" + site + "/inventory.ini"),
            "playbooks/operator-access-handoff.yml",
            "-e",
            "verself_site=" + site,
        ],
        cwd = ansible_dir,
        label = "ansible-playbook operator-access-handoff --site " + site,
    )

operator_access_handoff = task(
    implementation = _operator_access_handoff_impl,
    name = "operator-access-handoff",
    group = ["host"],
    summary = "Manually hand public SSH :22 to Pomerium and keep direct recovery on :2222.",
    args = {
        "site": args.string(default = "prod", description = "Deployment site."),
        "confirm": args.boolean(default = False, description = "Required confirmation for SSH listener handoff."),
    },
)
