"""aspect dev <action> — controller development helpers.

The local frontend task shells out to run-verself-web-local-dev.sh so env
discovery and tunnel setup remain in one place.
"""

load(".aspect/lib/helpers.axl", "SUBSTRATE_DIR", "checked_spawn", "inventory_check", "ws_path")

def _ansible_local(ctx, playbook, *extra_args):
    args_list = [playbook] + list(extra_args)
    return checked_spawn(
        ctx,
        "ansible-playbook",
        args_list,
        cwd = ws_path(ctx, SUBSTRATE_DIR, "ansible"),
        label = "ansible-playbook " + " ".join(args_list),
    )

def _install_impl(ctx):
    catalog = ws_path(ctx, "src/devtools/catalog.yml")
    return _ansible_local(ctx, "playbooks/setup-dev.yml", "-e", "@" + catalog)

def _sops_init_impl(ctx):
    return _ansible_local(ctx, "playbooks/setup-sops.yml")

def _hooks_install_impl(ctx):
    (ctx.std.process.command("git")
        .args(["config", "--unset-all", "core.hooksPath"])
        .stdout("piped").stderr("piped")
        .spawn().wait())
    return checked_spawn(ctx, "pre-commit", ["install"], label = "pre-commit install")

def _verself_web_impl(ctx):
    if inventory_check(ctx) != 0:
        return 1
    cli_args = []
    if ctx.args.print_env:
        cli_args.append("--print-env")
    return checked_spawn(
        ctx,
        ws_path(ctx, SUBSTRATE_DIR, "scripts/run-verself-web-local-dev.sh"),
        cli_args,
        cwd = ws_path(ctx, SUBSTRATE_DIR),
        label = "run-verself-web-local-dev.sh",
    )

install = task(
    implementation = _install_impl,
    name = "install",
    group = ["dev"],
    summary = "Install pinned controller development tools.",
)

sops_init = task(
    implementation = _sops_init_impl,
    name = "sops-init",
    group = ["dev"],
    summary = "Bootstrap SOPS + Age encryption.",
)

hooks_install = task(
    implementation = _hooks_install_impl,
    name = "hooks-install",
    group = ["dev"],
    summary = "Install repo git hooks via pre-commit.",
)

verself_web = task(
    implementation = _verself_web_impl,
    name = "verself-web",
    group = ["dev"],
    summary = "Start local verself-web dev tunnels and HMR server (console + docs + policy).",
    args = {
        "print_env": args.boolean(default = False, description = "Print resolved env and exit before starting HMR."),
    },
)
