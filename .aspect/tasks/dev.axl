"""aspect dev verself-web — local frontend loop.

The task shells out to run-verself-web-local-dev.sh so env discovery and tunnel
setup remain in one place.
"""

load(".aspect/lib/helpers.axl", "checked_spawn", "inventory_check", "ws_path")

_PLATFORM = "src/platform"

def _verself_web_impl(ctx):
    if inventory_check(ctx) != 0:
        return 1
    cli_args = []
    if ctx.args.print_env:
        cli_args.append("--print-env")
    return checked_spawn(
        ctx,
        ws_path(ctx, _PLATFORM, "scripts/run-verself-web-local-dev.sh"),
        cli_args,
        cwd = ws_path(ctx, _PLATFORM),
        label = "run-verself-web-local-dev.sh",
    )

verself_web = task(
    implementation = _verself_web_impl,
    name = "verself-web",
    group = ["dev"],
    summary = "Start local verself-web dev tunnels and HMR server (console + docs + policy).",
    args = {
        "print_env": args.boolean(default = False, description = "Print resolved env and exit before starting HMR."),
    },
)
