# Binaries
/verself
# Config (contains credentials)
verself.toml

# Terraform
src/provisioning-tools/terraform/.terraform/
src/provisioning-tools/terraform/.terraform.lock.hcl
src/provisioning-tools/terraform/terraform.tfstate
src/provisioning-tools/terraform/terraform.tfstate.backup
src/provisioning-tools/terraform/*.tfvars.json

# Ansible
src/host-configuration/ansible/*.retry
src/host-configuration/ansible/.cache/
src/host-configuration/ansible/inventory/*.ini
!src/host-configuration/ansible/inventory/*.example

# Legacy renderer cache.
.cache/

# Age private keys (NEVER commit)
**/keys.txt
*.age-key

# Go
*.exe
*.test
*.out
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
.build/

# Zig (vm-guest-telemetry has a local .gitignore for .zig-cache and zig-out)

# Reference repos (cloned for grep, not committed)
docs/references/

# CI build artifacts
src/platform/ci/output/rootfs.ext4
src/platform/ci/output/sbom.txt

# Logs
*.log

.claude/scheduled_tasks.lock

__pycache__
src/sandbox-rental-service/sandbox-rental-service

node_modules

# ClickHouse test artifacts (generated by e2e harness)
**/preprocessed_configs/
**/e2e/access/

# Materialized local build/deploy outputs
artifacts/

# Generated/rendered directories are materialized outputs.
**/__generated/
**/__rendered/

# Bazel convenience symlinks
/bazel-*

# Screenshots dropped into the working directory by macOS pasteboard
# / capture tools — never tracked.
Screenshot*.png
Screenshot*.jpg

# Generated OpenAPI artifacts. Authority is the Huma route source; the
# action graph rebuilds these into bazel-out via verself_openapi_yaml +
# verself_openapi_go_client. No on-disk source of truth.
src/*/openapi/openapi-*.yaml
src/*/openapi/internal-openapi-*.yaml
src/*/client/client.gen.go
src/*/internalclient/client.gen.go

# E2E smoke-test bundles, personas, Playwright traces, and query evidence
smoke-artifacts/
