# Binaries
/verself
# Config (contains credentials)
verself.toml

# Terraform
src/platform/terraform/.terraform/
src/platform/terraform/.terraform.lock.hcl
src/platform/terraform/terraform.tfstate
src/platform/terraform/terraform.tfstate.backup
src/platform/terraform/*.tfvars.json

# Ansible
src/platform/ansible/*.retry
src/platform/ansible/.cache/
src/platform/ansible/inventory/*.ini
!src/platform/ansible/inventory/*.example

# Renderer cache: aspect render --site=<site> writes everything Ansible
# discovers under .cache/render/<site>/ (inventory, group_vars, share/rendered).
# Tracked generated files used to live under src/platform/ansible/; they are
# intentionally absent now so PR review surfaces only authored CUE/Ansible.
.cache/
src/platform/ansible/group_vars/all/generated/
src/platform/ansible/share/rendered/
src/platform/ansible/handlers/component-systemd.yml

# Age private keys (NEVER commit)
**/keys.txt
*.age-key

# Go
*.exe
*.test
*.out
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
.build/

# Zig (vm-guest-telemetry has a local .gitignore for .zig-cache and zig-out)

# Reference repos (cloned for grep, not committed)
docs/references/

# CI build artifacts
src/platform/ci/output/rootfs.ext4
src/platform/ci/output/sbom.txt

# Logs
*.log

.claude/scheduled_tasks.lock

__pycache__
src/sandbox-rental-service/sandbox-rental-service

node_modules

# ClickHouse test artifacts (generated by e2e harness)
**/preprocessed_configs/
**/e2e/access/

# Materialized local build/deploy outputs
artifacts/

# Bazel convenience symlinks
/bazel-*

# E2E smoke-test bundles, personas, Playwright traces, and query evidence
smoke-artifacts/
