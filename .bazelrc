common --enable_bzlmod
common --noenable_workspace
common --announce_rc
common --lockfile_mode=error

# 30 min keeps the JVM warm across a typical edit-build-test cycle without
# letting Skyframe accumulate a day's worth of drift. The previous 24h value
# was the upstream of a desync where the server's stat-based file digest
# cache held a stale view of an in-flight edit (atomic-rename save with
# colliding mtime+size) and replayed it through every subsequent build until
# the server was restarted. Long-lived bazel servers are an anti-feature for
# repos under continuous parallel editing.
startup --max_idle_secs=1800

# Bazel caching is local-only. A shared remote cache couples bootstrap and deploy
# to a host service; keep cache state inside the invoking user's home directory.
build --disk_cache=~/.cache/bazel-disk
build --repository_cache=~/.cache/bazel-repo
build --incompatible_strict_action_env
build --jobs=auto
# Subscribe to kernel filesystem events for source-file invalidation instead
# of relying on stat-deltas at command start. Closes the stat-collision window
# that the prior --max_idle_secs=86400 footgun depended on.
build --watchfs

test --test_output=errors
test --test_summary=terse

build:ci --build_metadata=ROLE=CI
